<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
		xmlns:behaviors="clr-namespace:H.Avalonia.Behaviors">
	<Design.PreviewWith>
		<Border Padding="20">
			<!-- Add Controls for Previewer Here -->
		</Border>
	</Design.PreviewWith>

	<!-- ── Global Typography Defaults ──────────────────────────────────── -->
	<Style Selector="TextBlock">
		<Setter Property="FontFamily" Value="{StaticResource GcdsBodyFont}"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeBody}"/>
	</Style>
	<Style Selector="TextBox">
		<Setter Property="FontFamily" Value="{StaticResource GcdsBodyFont}"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeBody}"/>
	</Style>
	<Style Selector="Label">
		<Setter Property="FontFamily" Value="{StaticResource GcdsBodyFont}"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeBody}"/>
	</Style>

	<!-- Button Styles -->
	<Style Selector="Button">
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="Background" Value="{StaticResource DefaultHighlightBrush}" />
		<Setter Property="Foreground" Value="White" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Padding" Value="50, 10"/>
	</Style>
	<Style Selector="Button.generic-button">
	</Style>
	<Style Selector="Button:pointerover.user-prompt-button--confirm /template/ ContentPresenter">
		<Setter Property="Background" Value="{StaticResource GcdsDangerBrush}" />
	</Style>
	<Style Selector="Button.user-prompt-button--cancel">
		<Setter Property="Background" Value="#D3D3D3" />
	</Style>
	<Style Selector="DataGridCell Button.row-delete-button">
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="Button:pointerover.row-delete-button--pointerOver /template/ ContentPresenter">
		<Setter Property="Background" Value="{StaticResource GcdsDangerBrush}" />
	</Style>
	<Style Selector="Button.multiple-row-delete-button">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
	</Style>
	<Style Selector="Button.add-row-datagrid-button">
		<Setter Property="Margin" Value="20,0,20,0"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="Background" Value="{StaticResource GcdsBgPrimaryBrush}"/>
	</Style>
	<Style Selector="Button.calculate-results-button">
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="CornerRadius" Value="15" />
		<!-- <Setter Property="" Value="" /> -->
		<Setter Property="Padding" Value="20" />
		<Setter Property="Margin" Value="20" />
		<Setter Property="Width" Value="240" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="FontFamily" Value="{StaticResource GcdsHeadingFont}" />
		<Setter Property="Background" Value="{StaticResource GcdsBgPrimaryBrush}"/>
	</Style>
	<Style Selector="Button.add-management-period">
		<Setter Property="Margin" Value="10,20,0,0"/>
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderSubtleBrush}"/>
		<Setter Property="Background" Value="White"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="Width" Value="275"/>
		<Setter Property="Height" Value="45"/>
	</Style>
	<Style Selector="Button.add-group">
		<Setter Property="Margin" Value="10,20,0,0"/>
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderSubtleBrush}"/>
		<Setter Property="Background" Value="White"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="MinWidth" Value="175"/>
		<Setter Property="Height" Value="40"/>
	</Style>
	<Style Selector="Button.back-button">
		<Setter Property="Background" Value="{StaticResource GcdsBgLightBrush}" />
		<Setter Property="Foreground" Value="Black" />
	</Style>
	
	<Style Selector="Button.responsive-button">
		<Setter Property="Background" Value="{StaticResource DefaultHighlightBrush}" />
		<Setter Property="Foreground" Value="White" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Padding" Value="15,8"/>
		<Setter Property="MinWidth" Value="140"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="FontSize" Value="13"/>
	</Style>

	<!-- Style for responsive button content to handle text wrapping -->
	<Style Selector="Button.responsive-button > ContentPresenter > TextBlock">
		<Setter Property="TextWrapping" Value="Wrap"/>
		<Setter Property="TextAlignment" Value="Center"/>
		<Setter Property="MaxWidth" Value="130"/>
	</Style>

    <!-- DataGrid Styles -->
    <Style Selector="DataGridCell NumericUpDown">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ShowButtonSpinner" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="{Binding $parent[DataGridCell].Bounds.Width}"></Setter>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGridCell.numericStyle">
    </Style>

	<!-- GridSplitter Styles -->
	<Style Selector="GridSplitter.default-vertical-gridsplitter">
		<Setter Property="Background" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="Width" Value="2"/>
	</Style>

	<!-- Grid.Border Styles-->
	<Style Selector="Border.component-border">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>


	<!-- TextBlock Styles -->
	<Style Selector="TextBlock.title-textblock">
		<Setter Property="FontFamily" Value="{StaticResource GcdsHeadingFont}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeH6}" />
		<Setter Property="Foreground" Value="{StaticResource DefaultForegroundTextBrush}" />
		<Setter Property="Padding" Value="20" />
		<Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<Style Selector="TextBlock.step-title-textblock">
		<Setter Property="FontFamily" Value="{StaticResource GcdsHeadingFont}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeH4}" />
		<Setter Property="Foreground" Value="{StaticResource DefaultForegroundTextBrush}" />
		<Setter Property="TextWrapping" Value="Wrap" />
	</Style>

	<Style Selector="TextBlock.inline-text-block-error">
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsDangerBrush}"/>
		<Setter Property="FontSize" Value="14"/>
	</Style>

	<Style Selector="TextBlock.inline-text-block-succeed">
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsSuccessBrush}"/>
		<Setter Property="FontSize" Value="14"/>
	</Style>

	<!--TextBlock Styles - Disclaimer text-->
	<Style Selector="TextBlock.disclaimer">
		<Setter Property="FontStyle" Value="Italic"/>
		<Setter Property="FontSize" Value="12"/>
	</Style>

	<Style Selector="TextBlock.step-number">
		<Setter Property="FontFamily" Value="{StaticResource GcdsHeadingFont}"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeH5}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{StaticResource DefaultHighlightBrush}"/>
		<Setter Property="TextDecorations" Value="Underline"/>
		<Setter Property="Margin" Value="0,0,0,14"/>
	</Style>

	<Style Selector="TextBlock.step-number-description">
		<Setter Property="FontSize" Value="16"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="Margin" Value="0,0,4,0"/>
	</Style>

	<!-- TextBox Styles -->
	<Style Selector="TextBox.view-title">
		<Setter Property="FontFamily" Value="{StaticResource GcdsHeadingFont}"/>
		<Setter Property="FontSize" Value="{StaticResource GcdsFontSizeH1}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Margin" Value="0,10,0,0"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextPrimaryBrush}"/>
		<Setter Property="BorderThickness" Value="0"/>
	</Style>

	<!-- Border Styles -->
	<Style Selector="Border.title-underline">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="BorderThickness" Value="0,0,0,3"/>
		<Setter Property="Margin" Value="0,10,0,0"/>
	</Style>

	<Style Selector="Border.control-separator">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderSubtleBrush}"/>
		<Setter Property="BorderThickness" Value="0,0,0,3"/>
		<Setter Property="Margin" Value="0,10,0,0"/>
	</Style>

	<Style Selector="GridSplitter.default-horizontal-style">
		<Setter Property="ResizeDirection" Value="Rows"/>
		<Setter Property="Height" Value="1"/>
		<Setter Property="Background" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="BorderThickness" Value="0,0,0,3"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
	</Style>

	<!-- DataValidationErrors Styles-->
	<!--Textblock-->
	<Style Selector="DataValidationErrors">
		<Setter Property="ErrorTemplate">
			<DataTemplate>
				<ItemsControl ItemsSource="{Binding}">
					<ItemsControl.Styles>
						<Style Selector="TextBlock">
							<Setter Property="FontSize" Value="12"/>
							<Setter Property="TextWrapping" Value="Wrap" />
							<Setter Property="Foreground" Value="{StaticResource GcdsDangerBrush}"/>
						</Style>
					</ItemsControl.Styles>
				</ItemsControl>
			</DataTemplate>
		</Setter>
	</Style>

	<!-- Label Styles -->
	<!-- Style for labels that appear before input boxes -->
	<Style Selector="Label.input-label">
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="HorizontalContentAlignment" Value="Left"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="Foreground" Value="Black"/>
		<Setter Property="MinWidth" Value="220"/>
		<Setter Property="FontWeight" Value="Normal"/>
	</Style>

	<!-- TextBlock style for input labels (used in grids with SharedSizeGroup) -->
	<Style Selector="TextBlock.input-label-text">
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Foreground" Value="Black"/>
		<Setter Property="FontWeight" Value="Normal"/>
	</Style>

	<!-- Style for unit labels -->
	<Style Selector="Label.unit-label">
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="MinWidth" Value="120"/>
		<Setter Property="FontStyle" Value="Italic"/>
	</Style>

	<!-- Card Styles -->
	<Style Selector="Border.card">
		<Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
		<Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
		<Setter Property="BorderThickness" Value="{StaticResource CardBorderThickness}"/>
		<Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
		<Setter Property="Padding" Value="{StaticResource CardPadding}"/>
		<Setter Property="Margin" Value="{StaticResource CardMargin}"/>
	</Style>

	<Style Selector="Border.step-card">
		<Setter Property="Background" Value="White"/>
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="20"/>
		<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
	</Style>

	<!-- Step Container Border Style -->
	<!-- Shared style for step content containers used in Field and Rotation component views -->
	<Style Selector="Border.step-container">
		<Setter Property="Background" Value="White"/>
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="20"/>
		<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
	</Style>

	<Style Selector="Border.input-card">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderLightBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="6"/>
		<Setter Property="Padding" Value="16"/>
		<Setter Property="Background" Value="{StaticResource GcdsBgLightBrush}"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
	</Style>

	<!-- Input Card Hint Text Style -->
	<!-- Style for hint/help text that appears below inputs in input cards -->
	<Style Selector="TextBlock.input-hint">
		<Setter Property="FontSize" Value="11"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="Margin" Value="0,10,0,0"/>
	</Style>

	<!-- Timeline Card Styles -->
	<Style Selector="Border.timeline-card">
		<Setter Property="Background" Value="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}"/>
		<Setter Property="BorderBrush" Value="{Binding IsSelected, Converter={StaticResource BoolToBorderBrushConverter}}"/>
		<Setter Property="BorderThickness" Value="{Binding IsSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"/>
		<Setter Property="RenderTransform" Value="{Binding IsSelected, Converter={StaticResource BoolToScaleTransformConverter}}"/>
		<Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
		<Setter Property="MinWidth" Value="220"/>
		<Setter Property="MaxWidth" Value="240"/>
		<Setter Property="Padding" Value="{StaticResource CardPadding}"/>
	</Style>

	<Style Selector="Button:pointerover > Border.timeline-card">
		<Setter Property="BorderBrush" Value="{StaticResource CardSelectedBorderBrush}"/>
		<Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}"/>
	</Style>

    <!-- Animal Group Card Styles - Static styling without binding -->
    <Style Selector="Border.timeline-card.animal-group-card">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="RenderTransform" Value="scale(1.0)"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="MinWidth" Value="180"/>
        <Setter Property="MaxWidth" Value="200"/>
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
    </Style>

    <Style Selector="Button:pointerover > Border.timeline-card.animal-group-card">
        <Setter Property="BorderBrush" Value="{StaticResource GcdsSelectionBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource GcdsSelectionBgBrush}"/>
    </Style>

    <!-- Selected animal group card state - applied via code when needed -->
    <Style Selector="Border.timeline-card.animal-group-card.selected">
        <Setter Property="Background" Value="{StaticResource GcdsSelectionBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GcdsSelectionBorderBrush}"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    <Style Selector="Button:pointerover > Border.timeline-card.animal-group-card.selected">
        <Setter Property="BorderBrush" Value="{StaticResource GcdsSelectionBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource GcdsSelectionBgBrush}"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    <!-- Component List Card Styles -->
    <Style Selector="Border.component-card">
        <Setter Property="Background" Value="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}"/>
        <Setter Property="BorderBrush" Value="{Binding IsSelected, Converter={StaticResource BoolToBorderBrushConverter}}"/>
        <Setter Property="BorderThickness" Value="{Binding IsSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"/>
        <Setter Property="RenderTransform" Value="{Binding IsSelected, Converter={StaticResource BoolToScaleTransformConverter}}"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="MinHeight" Value="120"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
    </Style>

	<Style Selector="Button:pointerover > Border.component-card">
		<Setter Property="BorderBrush" Value="{StaticResource CardSelectedBorderBrush}"/>
		<Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}"/>
	</Style>

    <!-- Badge Styles -->
    <Style Selector="Border.step-badge">
        <Setter Property="Background" Value="{StaticResource BadgeBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="{StaticResource StepBadgeCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource StepBadgePadding}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="48"/>
    </Style>

    <Style Selector="Border.year-badge">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource BadgeBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="{StaticResource YearBadgeCornerRadius}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="{StaticResource YearBadgePadding}"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="48"/>
    </Style>

	<Style Selector="TextBlock.badge-text">
		<Setter Property="Foreground" Value="{StaticResource BadgeTextBrush}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
	</Style>

	<Style Selector="TextBlock.step-badge-text">
		<Setter Property="Foreground" Value="{StaticResource BadgeTextBrush}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
	</Style>

    <Style Selector="TextBlock.year-badge-text">
        <Setter Property="Foreground" Value="{StaticResource BadgeBackgroundBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.delete-text">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Delete Button Style -->
    <Style Selector="Button.delete-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource DeleteButtonBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="0"/> <!-- Override base/default button padding show text will be visible -->
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Foreground" Value="{StaticResource DeleteButtonBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <!--<Setter Property="Margin" Value="0,12,0,0"/>-->
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Delete Button Hover Effect -->
    <Style Selector="Button.delete-button:pointerover">
        <Setter Property="Background" Value="{StaticResource DeleteButtonBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{StaticResource DeleteButtonBrush}"/>
    </Style>

	<!-- Timeline Container Styles -->
	<Style Selector="Border.timeline-container">
		<Setter Property="Background" Value="White"/>
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="20"/>
		<Setter Property="Margin" Value="0,10"/>
		<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
	</Style>

	<Style Selector="TextBlock.timeline-header">
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="Margin" Value="0,0,0,10"/>
	</Style>

	<Style Selector="TextBlock.timeline-hint">
		<Setter Property="FontStyle" Value="Italic"/>
		<Setter Property="FontSize" Value="11"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="Margin" Value="0,8,0,0"/>
	</Style>

	<!-- Step Header Styles -->
	<Style Selector="StackPanel.step-header">
		<Setter Property="Orientation" Value="Horizontal"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Margin" Value="0,0,0,20"/>
	</Style>

	<!-- Empty State Styles -->
	<Style Selector="StackPanel.empty-state">
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="Spacing" Value="20"/>
		<Setter Property="Margin" Value="40"/>
	</Style>

	<Style Selector="TextBlock.empty-state-title">
		<Setter Property="FontSize" Value="24"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsBorderDefaultBrush}"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
	</Style>

	<Style Selector="TextBlock.empty-state-subtitle">
		<Setter Property="FontSize" Value="16"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextSecondaryBrush}"/>
		<Setter Property="FontStyle" Value="Italic"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
		<Setter Property="TextAlignment" Value="Center"/>
		<Setter Property="MaxWidth" Value="400"/>
	</Style>

	<Style Selector="Border.empty-state-tip">
		<Setter Property="Background" Value="{StaticResource GcdsBgLightBrush}"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="16,12"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
	</Style>

	<!-- Tip Icon Styles -->
	<Style Selector="Border.tip-icon">
		<Setter Property="Width" Value="16"/>
		<Setter Property="Height" Value="16"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Background" Value="{StaticResource GcdsLinkDefaultBrush}"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
	</Style>

	<Style Selector="TextBlock.tip-icon-text">
		<Setter Property="Text" Value="i"/>
		<Setter Property="FontSize" Value="10"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
	</Style>

	<!-- Section Heading Styles - For subsections within step containers -->
	<Style Selector="TextBlock.section-heading">
		<Setter Property="FontWeight" Value="Medium"/>
		<Setter Property="FontSize" Value="13"/>
		<Setter Property="Foreground" Value="{StaticResource GcdsTextPrimaryBrush}"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<Style Selector="TextBlock.stage-section-heading">
		<Setter Property="FontWeight" Value="Medium"/>
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="Margin" Value="0,0,0,16"/>
	</Style>

	<!-- NumericUpDown Styles -->
	<!-- Default style to select all text when the control receives focus -->
	<Style Selector="NumericUpDown">
		<Setter Property="(i:Interaction.Behaviors)">
			<i:BehaviorCollectionTemplate>
				<i:BehaviorCollection>
					<behaviors:SelectAllOnFocusBehavior/>
				</i:BehaviorCollection>
			</i:BehaviorCollectionTemplate>
		</Setter>
	</Style>
	<!-- Ensure only the focused/hovered NumericUpDown shows a highlight border -->
	<Style Selector="NumericUpDown /template/ TextBox">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderLightBrush}"/>
	</Style>
	<Style Selector="NumericUpDown:focus-within /template/ TextBox">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsFocusBrush}"/>
	</Style>
	<Style Selector="NumericUpDown:pointerover /template/ TextBox">
		<Setter Property="BorderBrush" Value="{StaticResource GcdsBorderDefaultBrush}"/>
	</Style>
</Styles>
