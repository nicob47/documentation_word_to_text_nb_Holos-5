<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:OptionsViews="clr-namespace:H.Avalonia.ViewModels.OptionsViews"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="H.Avalonia.Views.OptionsViews.OptionFarmView">

	<Design.DataContext>
		<OptionsViews:FarmSettingsViewModel />
	</Design.DataContext>
	
	<Grid>

		<ScrollViewer>
				<StackPanel Margin="20" Spacing="10" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">
					<TextBlock Text="{Binding [Label_Name].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_Name].Value, Source={StaticResource Loc}}" TextChanged="" Text="{Binding Data.FarmName, Mode=TwoWay}"  />
					<TextBlock Text="{Binding [Label_Comments].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_Comments].Value, Source={StaticResource Loc}}" Text="{Binding Data.FarmComments, Mode=TwoWay}"  />
					<TextBlock Text="{Binding [Label_Polygon].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_Polygon].Value, Source={StaticResource Loc}}" IsReadOnly="True" IsEnabled="False" Text="{Binding Data.PolygonId}"  />
					<TextBlock Text="{Binding [Label_Coordinates].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_Coordinates].Value, Source={StaticResource Loc}}" IsReadOnly="True" IsEnabled="False" Text="{Binding Data.Coordinates}" />

					<TextBlock Text="{Binding [Label_Province].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_Province].Value, Source={StaticResource Loc}}" IsReadOnly="True" IsEnabled="False" Text="{Binding Data.Province}"  />
					<TextBlock Text="{Binding [Label_HardinessZone].Value, Source={StaticResource Loc}}"/>
					<TextBox AutomationProperties.Name="{Binding [Label_HardinessZone].Value, Source={StaticResource Loc}}" IsReadOnly="True" IsEnabled="False" Text="{Binding Data.HardinessZoneString}" />
					<TextBlock Text="{Binding [Label_GrowingSeasonPrecipitation].Value, Source={StaticResource Loc}}">
						<Run Text=" "/>
						<Run Text="{Binding [Label_UnitMm].Value, Source={StaticResource Loc}}"/>
					</TextBlock>

					<NumericUpDown FormatString="{}{0:0.00}" Value="{Binding Data.GrowingSeasonPrecipitation, Mode=TwoWay}" />
					<TextBlock Text="{Binding [Label_GrowingSeasonEvapotranspiration].Value, Source={StaticResource Loc}}"  >
						<Run Text=" "/>
						<Run Text="{Binding [Label_UnitMm].Value, Source={StaticResource Loc}}"/>
					</TextBlock>
					<NumericUpDown FormatString="{}{0:0.00}" Value="{Binding Data.GrowingSeasonEvapotranspiration, Mode=TwoWay}" />
					<TextBlock Text="{Binding [Label_HolosOperationMode].Value, Source={StaticResource Loc}}" />
					<Grid >
						<!--<RadioButton IsChecked="{Binding ActiveFarm.IsBasicMode}" GroupName="OperationMode" Content="{Binding [Label_BasicMode].Value, Source={StaticResource Loc}}"></RadioButton>-->
						<!--<RadioButton GroupName="OperationMode" IsChecked="{Binding ActiveFarm.IsAdvancedMode}" HorizontalAlignment="Right" Content="{Binding [Label_AdvancedMode].Value, Source={StaticResource Loc}}"></RadioButton>-->
						<RadioButton GroupName="OperationMode" IsChecked="{Binding Data.IsBasicMode}" Content="{Binding [Label_BasicMode].Value, Source={StaticResource Loc}}"/>
						<RadioButton GroupName="OperationMode" IsChecked="{Binding Data.IsAdvancedMode}" Content="{Binding [Label_AdvancedMode].Value, Source={StaticResource Loc}}" HorizontalAlignment="Right"/>
					</Grid>
					<StackPanel>
						<TextBlock Text="{Binding [Label_UnitsOfMeasurement].Value, Source={StaticResource Loc}}"/>
						<ComboBox AutomationProperties.Name="{Binding [Label_UnitsOfMeasurement].Value, Source={StaticResource Loc}}" ItemsSource="{Binding Path=MeasurementSystemTypes}" SelectedItem="{Binding Path=SelectedMeasurementSystem}" HorizontalAlignment="Left" Width="350" Margin="0 10 0 0"/>
					</StackPanel>
				</StackPanel>
		</ScrollViewer>

	</Grid>
</UserControl>
