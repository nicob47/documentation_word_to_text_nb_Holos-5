<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
			 xmlns:viewSections="clr-namespace:H.Avalonia"
             x:Class="H.Avalonia.Views.OptionsViews.FileMenuViews.FileImportFarmView">

	<StackPanel Spacing="25" HorizontalAlignment="Center" VerticalAlignment="Center">

		<StackPanel Spacing="30"  Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
			<StackPanel >
				<TextBlock Text="{Binding [Label_ImportFarm].Value, Source={StaticResource Loc}}"  HorizontalAlignment="Center" Margin="0,0,0,15" FontWeight="Bold" FontSize="20" Foreground="#696969"/>
				<Button Content="{Binding [Label_SelectFarm].Value, Source={StaticResource Loc}}" Click="OnSelectFarmOption_Clicked" HorizontalAlignment="Center"/>
			</StackPanel>
			<Border BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="0,0,1,0" Margin="20,0" Height="" />
			<StackPanel >
				<TextBlock Text="{Binding [Label_BulkImportFarm].Value, Source={StaticResource Loc}}"  HorizontalAlignment="Center" Margin="0,0,0,15" FontWeight="Bold" FontSize="20" Foreground="#696969"/>
				<Button  Content="{Binding [Label_SelectFolder].Value, Source={StaticResource Loc}}" Click="OnSelectFolderOption_Clicked" HorizontalAlignment="Center"/>
			</StackPanel>

			
		</StackPanel>

		<StackPanel>
			<TextBlock Classes="disclaimer" IsVisible="{Binding ShowGrid}" Text="{Binding [Label_MultipleSelection].Value, Source={StaticResource Loc}}" >
			</TextBlock>

			<DataGrid Name="FarmsDataGrid" SelectionChanged="FarmsDataGrid_SelectionChanged" IsVisible="{Binding ShowGrid}" SelectedItem="{Binding Path=SelectedFarm}" ItemsSource="{Binding Farms}"  AutoGenerateColumns="False" SelectionMode="Extended" Margin="0 10 0 0" Padding="20" GridLinesVisibility="All" IsReadOnly="True" Height="250" BorderThickness="2"  BorderBrush="{StaticResource GcdsBorderLightBrush}" CornerRadius="10" Background="#f5f5f5">
				<DataGrid.Styles>
					<Style Selector="DataGridColumnHeader">
						<Setter Property="FontWeight" Value="Bold" />
						<Setter Property="FontSize" Value="14" />
					</Style>
				</DataGrid.Styles>
				<DataGrid.Columns>
					<DataGridTextColumn Header="{Binding [Label_FarmName].Value, Source={StaticResource Loc}}" Binding="{Binding Name}"  />
					<DataGridTextColumn Header="{Binding [Label_Comments].Value, Source={StaticResource Loc}}" Binding="{Binding Comments}"  />
					<DataGridTextColumn Header="{Binding [Label_CreatedOn].Value, Source={StaticResource Loc}}" Binding="{Binding DateCreated}" />
					<DataGridTextColumn Header="{Binding [Label_ModifiedOn].Value, Source={StaticResource Loc}}" Binding="{Binding DateModified}"  />
					<DataGridTextColumn Header="{Binding [Label_Guid].Value, Source={StaticResource Loc}}" Binding="{Binding Guid}"  />
				</DataGrid.Columns>
			</DataGrid>
			

			<Button Content="{Binding [Button_Import].Value, Source={StaticResource Loc}}" IsEnabled="{Binding CanImport}" Command="{Binding ImportFarms}" Margin="0 15 0 0" HorizontalAlignment="Center" IsVisible="{Binding ShowGrid}"/>
		</StackPanel>

		
	</StackPanel>
</UserControl>
