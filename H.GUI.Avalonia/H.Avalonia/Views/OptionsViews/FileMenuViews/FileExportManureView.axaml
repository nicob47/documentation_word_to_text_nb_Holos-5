<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.OptionsViews.FileMenuViews.FileExportManureView">

	<StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
		<TextBlock Text="{Binding [Label_ExportFarmProducedManure].Value, Source={StaticResource Loc}}" HorizontalAlignment="Center" Margin="" FontWeight="Bold" FontSize="30" Foreground="#696969" />
		<TextBlock TextWrapping="Wrap" Text="{Binding [Label_ExportManureDesc].Value, Source={StaticResource Loc}}"/>
		<Button Content="{Binding [Button_CreateManureExport].Value, Source={StaticResource Loc}}" Margin="" Command="{Binding }" HorizontalAlignment="Center"/>
		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="{Binding [Label_TotalManureProducedForAnimalType].Value, Source={StaticResource Loc}}"/>
			<TextBlock Text="test"/>
		</StackPanel>
		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="{Binding [Label_TotalManureProducedForAnimalType].Value, Source={StaticResource Loc}}"/>
			<TextBlock Text="test"/>
		</StackPanel>
		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="{Binding [Label_TotalManureProducedForAnimalType].Value, Source={StaticResource Loc}}"/>
			<TextBlock Text="test"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="{Binding [Label_TotalManureProducedForAnimalType].Value, Source={StaticResource Loc}}"/>
			<TextBlock Text="test"/>
		</StackPanel>
		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="{Binding [Label_TotalManureProducedForAnimalType].Value, Source={StaticResource Loc}}"/>
			<TextBlock Text="test"/>
		</StackPanel>
		</StackPanel>
</UserControl>
