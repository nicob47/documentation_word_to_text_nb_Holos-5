<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
             x:Class="H.Avalonia.Views.ResultViews.ResultsSidebarView">

	<Grid Name="MyResultsViewsGrid" HorizontalAlignment="Stretch">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

		<Grid Grid.Row="0" Grid.Column="0" Name="MyResultsHeaderHeaderGrid" HorizontalAlignment="Stretch">
			<StackPanel Margin="10,10,10,5" VerticalAlignment="Center">
				<Border Background="#F8F9FA" 
					   BorderBrush="#E9ECEF" 
					   BorderThickness="1" 
					   CornerRadius="6" 
					   Padding="20,16" 
					   Margin="0">

                    <Grid HorizontalAlignment="Stretch" RowDefinitions="*,*">
						<TextBlock Grid.Row="0" Classes="title-textblock" Text="{x:Static properties:Resources.TitleResults}" HorizontalAlignment="Left"/>
                        <ToggleSwitch Grid.Row="1" IsChecked="{Binding IsBasicMode, Mode=TwoWay}" OffContent="{x:Static properties:Resources.LabelBasicMode}" OnContent="{x:Static properties:Resources.LabelAdvancedMode}" ToolTip.Tip="Toggle between Basic and Advanced results view" HorizontalAlignment="Left" Margin="20, 0, 0, 0"/>
						<Button Grid.Row="1" HorizontalAlignment="Right" Padding="5" Margin="10,0" Background="Transparent" Classes="back-button" CornerRadius="50" Command="{Binding Path=OnOptionsExecute}">
							<Image Source="avares://H.Avalonia/Assets/Images/Icons/Gear-icon.png" Width="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
						</Button>
					</Grid>

				</Border>
			</StackPanel>
		</Grid>
        <!-- Basic Mode: Chapter headings for summary navigation -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" IsVisible="{Binding IsBasicMode}">
            <Border Background="#F8F9FA" 
                    BorderBrush="#E9ECEF" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="16,12" 
                    Margin="10,5,10,5">
                <StackPanel  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <ListBox SelectionMode="Single" Margin="5,0" SelectedItem="{Binding Path=SelectedItem}">
                        <ListBoxItem Content="Farm Profile"/>
                        <ListBoxItem Content="Annual Production Summary"/>
                        <ListBoxItem Content="Total GHG Emissions"/>
                        <ListBoxItem Content="Emissions Breakdown by Category"/>
                        <ListBoxItem Content="Carbon Sequestration Summary"/>
                        <ListBoxItem Content="Manure Management Overview"/>
                        <ListBoxItem Content="Key Findings and Recommendations"/>
                    </ListBox>
                </StackPanel>
            </Border>
        </ScrollViewer>
        <!-- Advanced Mode -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding !IsBasicMode}">
            <Border Background="#F8F9FA" 
                    BorderBrush="#E9ECEF" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="16,12" 
                    Margin="10,5,10,5">
                <StackPanel  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <ListBox SelectionMode="Single" Margin="5,0" SelectedItem="{Binding Path=SelectedItem}">
                        <ListBoxItem Content="{x:Static properties:Resources.TitleMultiYearCarbonModelling}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleEstimatesOfProduction}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleFeedEstimateReport}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.LabelManureManagement}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleEconomics}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleEmissionsPieChart}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleOverallEmissions}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleComponentEmissions}"/>
                        <ListBoxItem Content="{x:Static properties:Resources.TitleDetailedEmissionsReport}"/>
                    </ListBox>
                </StackPanel>
            </Border>
        </ScrollViewer>

		<Border Name="ButtonsBorder" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch" Height="120">
			<Border Background="#F8F9FA" 
                   BorderBrush="#E9ECEF" 
                   BorderThickness="1" 
                   CornerRadius="6" 
                   Padding="16,12" 
                   Margin="10,5,10,10">
                <WrapPanel HorizontalAlignment="Center" 
                          VerticalAlignment="Center" 
                          Orientation="Horizontal" 
                          Margin="10">
                    <Button Content="{x:Static properties:Resources.ButtonGoBack}" 
                            Command="{Binding Path=OnGoBackExecuted}" 
                            Classes="responsive-button" 
                            Margin="5"/>
                </WrapPanel>
            </Border>
        </Border>
	</Grid>
</UserControl>
