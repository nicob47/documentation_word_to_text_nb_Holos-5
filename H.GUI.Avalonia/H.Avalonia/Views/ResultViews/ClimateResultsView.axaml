<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:results="clr-namespace:H.Avalonia.ViewModels.Results"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="H.Avalonia.Views.ResultViews.ClimateResultsView"
             xmlns:progRing="clr-namespace:AvaloniaProgressRing;assembly=AvaloniaProgressRing">
    <Design.DataContext>
        <results:ClimateResultsViewModel/>
    </Design.DataContext>
    
    <Grid RowDefinitions="Auto, Auto, Auto, *">
        <StackPanel Grid.Row="0" 
                    Name="GoBackPanel"
                    PointerPressed="GoBackPanel_OnPointerPressed"
                    Margin="10, 10, 0, 20"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Cursor="Hand">
            <PathIcon Data="{StaticResource arrow_left_regular}"/>
            <Label Content="{Binding [Label_Back].Value, Source={StaticResource Loc}}"/>
        </StackPanel>
        <progRing:ProgressRing Grid.Row="1"
                               Width="30"
                               Height="30"
                               IsActive="{Binding IsProcessingData}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Foreground="Green"
                               Margin="0,-10,0,20"/>
        <Button Name="ExportDataButton"
                Grid.Row="2"
                Content="{Binding [Label_ExportToCSV].Value, Source={StaticResource Loc}}"
                IsEnabled="{Binding !IsProcessingData, Mode=TwoWay}"
                Click="ExportDataButton_OnClick"
                HorizontalAlignment="Right"
                Margin="20, 10"/>
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding ClimateResultsViewItems}"
                  Margin="20,0,20,20"
                  IsReadOnly="True"
                  ColumnHeaderTheme="">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding [Label_Latitude].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding Latitude}"
                                    Width="*"/>
                <DataGridTextColumn Header="{Binding [Label_Longitude].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding Longitude}"
                                    Width="*"/>
                <DataGridTextColumn Header="{Binding [Label_Year].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding Year}"
                                    Width="*"/>
                <DataGridTextColumn Header="{Binding [Label_TotalPPT].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding TotalPPT, StringFormat={}{0:0.##}}"
                                    Width="*"/>
                <DataGridTextColumn Header="{Binding [Label_TotalPET].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding TotalPET, StringFormat={}{0:0.##}}"
                                    Width="*"/>
                <DataGridTextColumn Header="{Binding [Label_MonthlyPPT].Value, Source={StaticResource Loc}}"
                                    Binding="{Binding MonthlyPPT, StringFormat={}{0:0.##}}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    
</UserControl>
