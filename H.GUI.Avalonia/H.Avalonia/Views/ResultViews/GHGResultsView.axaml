<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvcore="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="H.Avalonia.Views.ResultViews.GHGResultsView">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header: farm name + carbon strategy + Recalculate button -->
        <Border Grid.Row="0"
                Background="#f8f9fa"
                BorderBrush="#dee2e6"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="GHG &amp; Carbon Results"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1f497a"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Farm: " FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding FarmName}" FontSize="13" Margin="0,0,16,0"/>
                        <TextBlock Text="Model: " FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding CarbonModellingStrategy}" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Strategy:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding AvailableCarbonStrategies}"
                              SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}"
                              MinWidth="140"
                              IsEnabled="{Binding !IsProcessingData}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    <Button Content="Recalculate"
                            Command="{Binding RecalculateCommand}"
                            Classes="responsive-button"
                            IsEnabled="{Binding !IsProcessingData}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <Button Content="Export to Excel"
                            Command="{Binding ExportFieldResultsCommand}"
                            Classes="responsive-button"
                            Padding="16,8"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error banner (visible only when LastErrorMessage is set) -->
        <Border Grid.Row="1"
                Background="#fff5f5"
                BorderBrush="#fed7d7"
                BorderThickness="0,0,0,1"
                Padding="20,12"
                IsVisible="{Binding LastErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Analysis error: " FontWeight="SemiBold" Foreground="#c53030"/>
                <TextBlock Text="{Binding LastErrorMessage}" Foreground="#c53030" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Processing indicator -->
        <Border Grid.Row="2"
                Background="#fffaf0"
                Padding="20,8"
                IsVisible="{Binding IsProcessingData}">
            <TextBlock Text="Running carbon analysis..." FontStyle="Italic" Foreground="#744210"/>
        </Border>

        <!-- Results grids (scrollable so field + shelterbelt sections stack without clipping) -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>

                <TextBlock Text="No results yet. Click Recalculate, or add a field with crop view items to the active farm and try again."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#6c757d"
                           FontStyle="Italic"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Margin="20"
                           TextAlignment="Center"
                           IsVisible="{Binding !HasResults}"/>

                <StackPanel IsVisible="{Binding HasResults}" Margin="20">

                    <!-- Soil carbon trend: one line series per field across years -->
                    <TextBlock Text="Soil organic carbon trend (kg C ha⁻¹)"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#2c3e50"
                               Margin="0,0,0,8"/>
                    <Border BorderBrush="#dee2e6"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8"
                            Margin="0,0,0,24"
                            Background="White">
                        <!-- LegendPosition="Hidden" works around a LiveChartsCore 2.0.0-rc1
                             IndexOutOfRangeException in SKDefaultLegend.Draw that fires when
                             rendering the default legend. With one field the legend conveys no
                             information; the line itself is labelled by the chart's tooltip on
                             hover. Re-enable once the library ships a stable release without
                             the legend bug. -->
                        <lvcore:CartesianChart Series="{Binding SoilCarbonTrendSeries}"
                                               XAxes="{Binding SoilCarbonTrendXAxes}"
                                               LegendPosition="Hidden"
                                               Height="280"/>
                    </Border>

                    <!-- Field-level per-year carbon results -->
                    <TextBlock Text="Field carbon results (per field × year)"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#2c3e50"
                               Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding YearResults}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80"/>
                            <DataGridTextColumn Header="Field" Binding="{Binding FieldName}" Width="*"/>
                            <DataGridTextColumn Header="Crop" Binding="{Binding CropType}" Width="*"/>
                            <DataGridTextColumn Header="Area (ha)" Binding="{Binding Area, StringFormat='{}{0:N2}'}" Width="100"/>
                            <DataGridTextColumn Header="Above-Ground C (kg/ha)" Binding="{Binding AboveGroundCarbonInput, StringFormat='{}{0:N1}'}" Width="160"/>
                            <DataGridTextColumn Header="Below-Ground C (kg/ha)" Binding="{Binding BelowGroundCarbonInput, StringFormat='{}{0:N1}'}" Width="160"/>
                            <DataGridTextColumn Header="Manure C (kg/ha)" Binding="{Binding ManureCarbonInput, StringFormat='{}{0:N1}'}" Width="130"/>
                            <DataGridTextColumn Header="Total C inputs (kg/ha)" Binding="{Binding TotalCarbonInputs, StringFormat='{}{0:N1}'}" Width="150"/>
                            <DataGridTextColumn Header="Soil C (kg/ha)" Binding="{Binding SoilCarbon, StringFormat='{}{0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="Δ Soil C (kg/ha/yr)" Binding="{Binding ChangeInSoilCarbon, StringFormat='{}{0:N3}'}" Width="140"/>
                            <DataGridTextColumn Header="Manure N (kg)" Binding="{Binding NitrogenAppliedFromManure, StringFormat='{}{0:N1}'}" Width="120"/>
                            <DataGridTextColumn Header="Direct N₂O (kg/ha)" Binding="{Binding DirectN2OPerHectare, StringFormat='{}{0:N3}'}" Width="140"/>
                            <DataGridTextColumn Header="Indirect N₂O (kg/ha)" Binding="{Binding IndirectN2OPerHectare, StringFormat='{}{0:N3}'}" Width="150"/>
                            <DataGridTextColumn Header="Total N₂O (kg/ha)" Binding="{Binding TotalN2OPerHectare, StringFormat='{}{0:N3}'}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Shelterbelt section, only visible when the farm has shelterbelt components -->
                    <StackPanel IsVisible="{Binding HasShelterbeltResults}" Margin="0,24,0,0">
                        <TextBlock Text="Shelterbelt carbon results (per shelterbelt × year)"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2c3e50"
                                   Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ShelterbeltYearResults}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80"/>
                                <DataGridTextColumn Header="Shelterbelt" Binding="{Binding ShelterbeltName}" Width="*"/>
                                <DataGridTextColumn Header="Living Biomass C (Mg/km)" Binding="{Binding TotalLivingBiomassCarbon, StringFormat='{}{0:N2}'}" Width="170"/>
                                <DataGridTextColumn Header="Δ Living Biomass C" Binding="{Binding TotalLivingBiomassCarbonChange, StringFormat='{}{0:N3}'}" Width="150"/>
                                <DataGridTextColumn Header="DOM C (Mg/km)" Binding="{Binding TotalDeadOrganicMatterCarbon, StringFormat='{}{0:N2}'}" Width="130"/>
                                <DataGridTextColumn Header="Δ DOM C" Binding="{Binding TotalDeadOrganicMatterChange, StringFormat='{}{0:N3}'}" Width="110"/>
                                <DataGridTextColumn Header="Total Ecosystem C (Mg/km)" Binding="{Binding TotalEcosystemCarbon, StringFormat='{}{0:N2}'}" Width="180"/>
                                <DataGridTextColumn Header="Δ Total Ecosystem C" Binding="{Binding TotalEcosystemCarbonChange, StringFormat='{}{0:N3}'}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
