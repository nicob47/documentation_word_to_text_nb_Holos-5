<UserControl  xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:viewModels="clr-namespace:H.Avalonia.ViewModels"
			 xmlns:valueConverters="clr-namespace:H.Infrastructure.Controls.ValueConverters;assembly=H.Infrastructure"
			 xmlns:h="clr-namespace:H.Avalonia"
			 xmlns:disclaimer="clr-namespace:H.Avalonia.ViewModels.SupportingViews.Disclaimer"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="720"
			 x:DataType="disclaimer:DisclaimerViewModelDesign"
             x:Class="H.Avalonia.Views.SupportingViews.Disclaimer.DisclaimerView">

	<Design.DataContext>
		<disclaimer:DisclaimerViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
		<!--<valueConverters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
		<valueConverters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />-->
	</UserControl.Resources>

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Row 0: Version + Language selector -->
		<Grid Grid.Row="0" Margin="0,0,0,16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
				<Label Content="{Binding VersionString}"/>
				<TextBlock VerticalAlignment="Center">
					<Run>(</Run>
					<Run Text="{x:Static h:GuiConstants.VersionReleaseDateString}"/>
					<Run>)</Run>
				</TextBlock>
			</StackPanel>
			<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
				<Label Content="{Binding [LabelLanguage].Value, Source={StaticResource Loc}}" VerticalAlignment="Center"/>
				<ComboBox AutomationProperties.Name="{Binding [LabelLanguage].Value, Source={StaticResource Loc}}"  ItemsSource="{Binding LanguageCollection}"
						  SelectedItem="{Binding SelectedLanguage}"
						  MinWidth="120"
						  Margin="5,0,0,0"/>
			</StackPanel>
		</Grid>

		<!-- Row 1: About Holos -->
		<Border Grid.Row="1" BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10" Background="{StaticResource GcdsBgLightBrush}">
			<TextBlock TextWrapping="Wrap" Text="{Binding AboutHolosString}"/>
		</Border>

		<!-- Row 2: To Be Kept Informed -->
		<Border Grid.Row="2" BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10" Background="{StaticResource GcdsBgLightBrush}">
			<TextBlock TextWrapping="Wrap" Text="{Binding ToBeKeptInformedString}"/>
		</Border>

		<!-- Row 3: Disclaimer - expands to fill remaining space -->
		<Grid Grid.Row="3" Margin="0,0,0,10">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<TextBlock Grid.Row="0"
					   FontFamily="{StaticResource GcdsHeadingFont}"
					   FontSize="{StaticResource GcdsFontSizeH6}"
					   FontWeight="Bold"
					   Foreground="{StaticResource GcdsTextPrimaryBrush}"
					   Text="{Binding DisclaimerTitle}"
					   Margin="0,0,0,8"/>
			<Border Grid.Row="1" BorderBrush="{StaticResource GcdsBorderDefaultBrush}" BorderThickness="1" CornerRadius="4">
				<ScrollViewer>
					<TextBlock TextWrapping="Wrap" Text="{Binding DisclaimerText}" Margin="8"/>
				</ScrollViewer>
			</Border>
		</Grid>

		<!-- Row 4: OK button -->
		<Button Grid.Row="4"
				IsDefault="True"
				Click="Button_OnClick"
				HorizontalAlignment="Center"
				Padding="24,6"
				Content="{Binding [LabelOk].Value, Source={StaticResource Loc}}"/>
	</Grid>
</UserControl>
