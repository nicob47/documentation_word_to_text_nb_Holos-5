<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             xmlns:vm="clr-namespace:H.Avalonia.ViewModels.SupportingViews"
             x:Class="H.Avalonia.Views.SupportingViews.DietFormulatorView">

    <Design.DataContext>
        <vm:DietFormulatorViewModelDesign />
    </Design.DataContext>

    <StackPanel Margin="20">
        
        <!-- Header -->
        <TextBlock Text="{Binding [Label_DietFormulator].Value, Source={StaticResource Loc}}" 
                   FontSize="{StaticResource GcdsFontSizeH4}" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center" />

        <!-- Search Bar -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Grid Width="300" VerticalAlignment="Center">
                <TextBox Text="{Binding SearchText}" 
                         Watermark="{Binding [Label_SearchDietsWatermark].Value, Source={StaticResource Loc}}" 
                         VerticalContentAlignment="Center" 
                         VerticalAlignment="Center" 
                         Foreground="{StaticResource GcdsTextSecondaryBrush}" 
                         BorderBrush="{StaticResource GcdsBorderLightBrush}"
                         BorderThickness="2" 
                         FontWeight="SemiBold" 
                         Padding="40,10,0,10" />
                <Image Source="avares://H.Avalonia/Assets/Images/Icons/search-icon.png" 
                       Width="20" 
                       Height="20" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Left" 
                       Margin="10,0"/>
            </Grid>
        </StackPanel>

        <!-- Diet Data Grid -->
        <DataGrid SelectedItem="{Binding SelectedDiet}" 
                  ItemsSource="{Binding Diets}"  
                  AutoGenerateColumns="False" 
                  Margin="0,20,0,0" 
                  Padding="20" 
                  GridLinesVisibility="All" 
                  IsReadOnly="True" 
                  Height="400" 
                  BorderThickness="2"  
                  BorderBrush="{StaticResource GcdsBorderLightBrush}" 
                  CornerRadius="10" 
                  Background="{StaticResource GcdsBgLightBrush}">
            
            <DataGrid.Styles>
                <Style Selector="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="FontSize" Value="{StaticResource GcdsFontSizeBody}" />
                </Style>
            </DataGrid.Styles>

            <DataGrid.Columns>
                <!-- Diet Name -->
                <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding Name}" 
                                    Width="200" />
                
                <!-- Animal Type -->
                <DataGridTextColumn Header="{Binding [Label_AnimalType].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding AnimalType}" 
                                    Width="150" />
                
                <!-- Diet Type -->
                <DataGridTextColumn Header="{Binding [Label_DietType].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding DietType}" 
                                    Width="150" />
                
                <!-- Crude Protein -->
                <DataGridTextColumn Header="{Binding [Label_CrudeProtein].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding CrudeProtein, StringFormat='{}{0:F2}'}" 
                                    Width="120" />
                
                <!-- Total Digestible Nutrient -->
                <DataGridTextColumn Header="{Binding [Label_TotalDigestibleNutrient].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F2}'}" 
                                    Width="120" />
                
                <!-- Forage -->
                <DataGridTextColumn Header="{Binding [Label_Forage].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding Forage, StringFormat='{}{0:F2}'}" 
                                    Width="100" />
                
                <!-- Daily Dry Matter Feed Intake -->
                <DataGridTextColumn Header="{Binding [Label_DailyDryMatterFeedIntake].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding DailyDryMatterFeedIntakeOfFeed, StringFormat='{}{0:F2}'}" 
                                    Width="150" />
                
                <!-- Methane Conversion Factor -->
                <DataGridTextColumn Header="{Binding [Label_MethaneConversionFactor].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding MethaneConversionFactor, StringFormat='{}{0:F3}'}" 
                                    Width="150" />
                
                <!-- Comments -->
                <DataGridTextColumn Header="{Binding [Label_Comments].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding Comments}" 
                                    Width="200" />
                
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="{Binding [Label_TotalDiets].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Diets.Count}" FontWeight="Bold" />
        </StackPanel>

    </StackPanel>
</UserControl>