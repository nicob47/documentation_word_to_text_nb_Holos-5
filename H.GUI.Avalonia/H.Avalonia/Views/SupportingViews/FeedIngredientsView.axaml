<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="700"
             xmlns:vm="clr-namespace:H.Avalonia.ViewModels.SupportingViews"
             xmlns:enums="clr-namespace:H.Core.Enumerations;assembly=H.Core"
             x:Class="H.Avalonia.Views.SupportingViews.FeedIngredientsView">

    <Design.DataContext>
        <vm:FeedIngredientsViewModelDesign />
    </Design.DataContext>

    <StackPanel Margin="20">
        
        <!-- Header -->
        <TextBlock Text="{Binding [Label_FeedIngredients].Value, Source={StaticResource Loc}}" 
                   FontSize="{StaticResource GcdsFontSizeH4}" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center" />

        <!-- Controls Panel -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            
            <!-- Animal Type Selection -->
            <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                <TextBlock Text="{Binding [Label_AnimalType].Value, Source={StaticResource Loc}}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5" />
                <ComboBox Width="200" 
                          SelectedItem="{Binding SelectedAnimalType}"
                          ItemsSource="{Binding AvailableAnimalTypes}" />
            </StackPanel>
            
            <!-- Search Bar -->
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding [Label_SearchIngredients].Value, Source={StaticResource Loc}}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5" />
                <Grid Width="300" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchText}" 
                             Watermark="{Binding [Label_SearchIngredientsByIFN].Value, Source={StaticResource Loc}}" 
                             VerticalContentAlignment="Center" 
                             VerticalAlignment="Center" 
                             Foreground="{StaticResource GcdsTextSecondaryBrush}" 
                             BorderBrush="{StaticResource GcdsBorderLightBrush}"
                             BorderThickness="2" 
                             FontWeight="SemiBold" 
                             Padding="40,10,0,10" />
                    <Image Source="avares://H.Avalonia/Assets/Images/Icons/search-icon.png" 
                           Width="20" 
                           Height="20" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Left" 
                           Margin="10,0"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Feed Ingredients Data Grid -->
        <DataGrid SelectedItem="{Binding SelectedIngredient}" 
                  ItemsSource="{Binding Ingredients}"  
                  AutoGenerateColumns="False" 
                  Margin="0,20,0,0" 
                  Padding="20" 
                  GridLinesVisibility="All" 
                  IsReadOnly="True" 
                  Height="500" 
                  BorderThickness="2"  
                  BorderBrush="{StaticResource GcdsBorderLightBrush}" 
                  CanUserResizeColumns="True"
                  CornerRadius="10" 
                  Background="{StaticResource GcdsBgLightBrush}">
            
            <DataGrid.Styles>
                <Style Selector="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="FontSize" Value="12" />
                </Style>
            </DataGrid.Styles>

            <DataGrid.Columns>
                
                <!-- Ingredient Type -->
                <DataGridTextColumn Header="{Binding [Label_IngredientType].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding IngredientTypeString}" 
                                    Width="200"/>
                
                <!-- IFN -->
                <DataGridTextColumn Header="{Binding [Label_IFN].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding IFN}" 
                                    Width="Auto"/>
                
                <!-- Dry Matter -->
                <DataGridTextColumn Header="{Binding [Label_DryMatter].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding DryMatter, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
                <!-- Crude Protein -->
                <DataGridTextColumn Header="{Binding [Label_CrudeProtein].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding CrudeProtein, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
                <!-- Total Digestible Nutrient -->
                <DataGridTextColumn Header="{Binding [Label_TDNPercent].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
                <!-- Fat -->
                <DataGridTextColumn Header="{Binding [Label_FatPercent].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding Fat, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
                <!-- Crude Fiber -->
                <DataGridTextColumn Header="{Binding [Label_CrudeFiberPercent].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding CrudeFiber, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
                <!-- Forage -->
                <DataGridTextColumn Header="{Binding [Label_Forage].Value, Source={StaticResource Loc}}" 
                                    Binding="{Binding Forage, StringFormat='{}{0:F1}'}" 
                                    Width="SizeToHeader" />
                
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="{Binding [Label_TotalIngredients].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Ingredients.Count}" FontWeight="Bold" />
            <TextBlock Text="{Binding [Label_ForUnit].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" Margin="10,0,0,0" />
            <TextBlock Text="{Binding SelectedAnimalType}" FontWeight="Bold" />
        </StackPanel>

    </StackPanel>
</UserControl>