<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:H.Avalonia.ViewModels.SupportingViews.DietFormulator"
        xmlns:infrastructure="clr-namespace:H.Infrastructure.Controls.ValueConverters;assembly=H.Infrastructure"
        mc:Ignorable="d"
        d:DesignWidth="1400" d:DesignHeight="820"
        Width="1400" Height="820"
        MinWidth="950" MinHeight="550"
        CanResize="True"
        Title="{Binding [Label_DietFormulator].Value, Source={StaticResource Loc}}"
        WindowStartupLocation="CenterOwner"
        x:Class="H.Avalonia.Views.SupportingViews.DietFormulator.DietFormulatorWindow">

    <Window.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="16">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{Binding [Label_DietFormulator].Value, Source={StaticResource Loc}}"
                       FontSize="{StaticResource GcdsFontSizeH4}"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding AnimalType, Converter={StaticResource EnumDescriptionConverter}, StringFormat='Scope: {0}'}"
                       FontSize="{StaticResource GcdsFontSizeSmall}"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
        </StackPanel>

        <!-- Three-grid layout: MyDiets (top-left), AvailableIngredients (bottom-left), SelectedDietIngredients (right) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,8,2*" RowDefinitions="*,8,*">

            <!-- ── MY DIETS (top-left) ── -->
            <Border Grid.Row="0" Grid.RowSpan="1" Grid.Column="0"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Step pill + heading on one line; description below to wrap freely -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10,8,10,2" VerticalAlignment="Center">
                        <Border Classes="step-badge" VerticalAlignment="Center">
                            <TextBlock Text="{Binding [Label_DietFormulatorStep1].Value, Source={StaticResource Loc}}"
                                       Classes="step-badge-text"/>
                        </Border>
                        <TextBlock Text="{Binding [Label_Diets].Value, Source={StaticResource Loc}}"
                                   FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="{Binding [Label_DietFormulatorStep1Description].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="10,0,10,8"/>
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding MyDiets}"
                              SelectedItem="{Binding SelectedDiet}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding Name}" Width="*"/>
                            <DataGridTemplateColumn Header="{Binding [Label_Origin].Value, Source={StaticResource Loc}}"
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,2" Padding="6,1" CornerRadius="3"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{StaticResource GcdsSelectionBgBrush}"
                                                IsVisible="{Binding !IsDefaultDiet}">
                                            <TextBlock Text="{Binding [Label_CustomDiet].Value, Source={StaticResource Loc}}"
                                                       FontSize="{StaticResource GcdsFontSizeSmall}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── AVAILABLE INGREDIENTS (bottom-left) ── -->
            <Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <!-- Step pill + heading on one line; description below to wrap freely -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10,8,10,2" VerticalAlignment="Center">
                        <Border Classes="step-badge" VerticalAlignment="Center">
                            <TextBlock Text="{Binding [Label_DietFormulatorStep2].Value, Source={StaticResource Loc}}"
                                       Classes="step-badge-text"/>
                        </Border>
                        <TextBlock Text="{Binding [Label_AvailableIngredients].Value, Source={StaticResource Loc}}"
                                   FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="{Binding [Label_DietFormulatorStep2Description].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="10,0,10,6"/>
                    <!-- Toolbar: search box + Add to selected diet (one row, save vertical space) -->
                    <Grid Grid.Row="2" Margin="10,0,10,8" ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0"
                                 AutomationProperties.Name="{Binding [Label_SearchIngredientsWatermark].Value, Source={StaticResource Loc}}"
                                 Text="{Binding IngredientSearchText, Mode=TwoWay}"
                                 Watermark="{Binding [Label_SearchIngredientsWatermark].Value, Source={StaticResource Loc}}"
                                 FontSize="{StaticResource GcdsFontSizeSmall}"
                                 Padding="8,4"
                                 VerticalContentAlignment="Center">
                            <!-- Inline clear button: only shown when there's text to clear -->
                            <TextBox.InnerRightContent>
                                <Button Command="{Binding ClearIngredientSearchCommand}"
                                        IsVisible="{Binding IngredientSearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="6,0"
                                        Margin="0,0,4,0"
                                        Cursor="Hand"
                                        ToolTip.Tip="Clear search">
                                    <TextBlock Text="✕"
                                               FontSize="{StaticResource GcdsFontSizeSmall}"
                                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </TextBox.InnerRightContent>
                        </TextBox>
                        <Button Grid.Column="2"
                                Content="{Binding [Label_AddIngredientToDiet].Value, Source={StaticResource Loc}}"
                                Command="{Binding AddIngredientCommand}"
                                Padding="10,4"
                                FontSize="{StaticResource GcdsFontSizeSmall}"/>
                    </Grid>
                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding AvailableIngredients}"
                              SelectedItem="{Binding SelectedAvailableIngredient}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding IngredientTypeString}"
                                                Width="*"
                                                MinWidth="180"/>
                            <DataGridTextColumn Header="CP %"
                                                Binding="{Binding CrudeProtein, StringFormat='{}{0:F1}'}"
                                                Width="Auto"
                                                MinWidth="70"/>
                            <DataGridTextColumn Header="TDN %"
                                                Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F1}'}"
                                                Width="Auto"
                                                MinWidth="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── SELECTED DIET INGREDIENTS (right, full height) ── -->
            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
                    <!-- Header: step pill + heading + working diet name on one line; Step 3 description below -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="4" Margin="10,8">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border Classes="step-badge" VerticalAlignment="Center">
                                <TextBlock Text="{Binding [Label_DietFormulatorStep3].Value, Source={StaticResource Loc}}"
                                           Classes="step-badge-text"/>
                            </Border>
                            <TextBlock Text="{Binding [Label_SelectedDietIngredients].Value, Source={StaticResource Loc}}"
                                       FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding WorkingDietName}"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"
                                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Step3Guidance}"
                                   FontSize="{StaticResource GcdsFontSizeSmall}"
                                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <!-- Toolbar: Remove from diet -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,8" Spacing="8">
                        <Button Content="{Binding [Label_RemoveIngredientFromDiet].Value, Source={StaticResource Loc}}"
                                Command="{Binding RemoveIngredientCommand}"
                                Padding="10,4"
                                FontSize="{StaticResource GcdsFontSizeSmall}"/>
                    </StackPanel>
                    <!-- Editable ingredients grid: only the PercentageInDiet column is editable -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SelectedDietIngredients}"
                              SelectedItem="{Binding SelectedIngredientInDiet}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding IngredientTypeString}"
                                                IsReadOnly="True"
                                                Width="*"
                                                MinWidth="220"/>
                            <!--
                                StringFormat is not used here: Avalonia does not support
                                StringFormat on two-way bindings because the formatted text
                                cannot be reliably parsed back to a double on commit.
                                The cell shows the raw double value while editing; the live
                                "Diet Totals" panel below the grid still displays formatted
                                percentages so users see neat values in the summary.
                            -->
                            <DataGridTextColumn Header="% in Diet"
                                                Binding="{Binding PercentageInDiet, Mode=TwoWay}"
                                                IsReadOnly="False"
                                                Width="Auto"
                                                MinWidth="100"/>
                            <DataGridTextColumn Header="CP %"
                                                Binding="{Binding CrudeProtein, StringFormat='{}{0:F1}'}"
                                                IsReadOnly="True"
                                                Width="Auto"
                                                MinWidth="80"/>
                            <DataGridTextColumn Header="TDN %"
                                                Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F1}'}"
                                                IsReadOnly="True"
                                                Width="Auto"
                                                MinWidth="80"/>
                            <DataGridTextColumn Header="Forage %"
                                                Binding="{Binding Forage, StringFormat='{}{0:F1}'}"
                                                IsReadOnly="True"
                                                Width="Auto"
                                                MinWidth="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ── LIVE TOTALS PANEL ── -->
                    <Border Grid.Row="3" Background="{StaticResource GcdsSelectionBgBrush}" Padding="12,10" Margin="8,8,8,0" CornerRadius="4">
                        <StackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="{Binding [Label_DietTotals].Value, Source={StaticResource Loc}}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"/>
                            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding TotalCrudeProtein, StringFormat='CP: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding TotalTDN, StringFormat='TDN: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="{Binding TotalForage, StringFormat='Forage: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3"
                                           Text="{Binding TotalNDF, StringFormat='NDF: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding TotalADF, StringFormat='ADF: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding TotalFat, StringFormat='Fat: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Text="{Binding TotalAsh, StringFormat='Ash: {0:F1}%'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="3"
                                           Text="{Binding TotalME, StringFormat='ME: {0:F2} Mcal/kg'}"
                                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── PERCENTAGE SUM VALIDATION ── -->
                    <Border Grid.Row="4" Padding="12,8" Margin="8,4,8,8" CornerRadius="4"
                            Background="{StaticResource GcdsBgLightBrush}"
                            BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding [Label_TotalPercentageInDiet].Value, Source={StaticResource Loc}}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"/>
                            <TextBlock Text="{Binding PercentageSum, StringFormat='{}{0:F1}%'}"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"
                                       FontWeight="Bold"/>
                            <!-- Valid sum indicator -->
                            <TextBlock Text="✓"
                                       Foreground="Green"
                                       FontWeight="Bold"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"
                                       IsVisible="{Binding IsPercentageSumValid}"/>
                            <!-- Invalid sum warning -->
                            <TextBlock Text="{Binding [Warning_PercentageSumNot100].Value, Source={StaticResource Loc}}"
                                       Foreground="{StaticResource GcdsWarningBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource GcdsFontSizeSmall}"
                                       IsVisible="{Binding !IsPercentageSumValid}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── INLINE "SAVE AS CUSTOM" NAME PROMPT ── -->
        <Border Grid.Row="2" Padding="12,8" Margin="0,12,0,0" CornerRadius="4"
                Background="{StaticResource GcdsSelectionBgBrush}"
                BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1"
                IsVisible="{Binding IsSaveAsPromptVisible}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding [Label_NewDietName].Value, Source={StaticResource Loc}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource GcdsFontSizeSmall}"/>
                <TextBox AutomationProperties.Name="{Binding [Label_NewDietName].Value, Source={StaticResource Loc}}" Text="{Binding SaveAsName, Mode=TwoWay}"
                         MinWidth="280"
                         Watermark="{Binding [Label_NewDietNameWatermark].Value, Source={StaticResource Loc}}"/>
                <Button Content="{Binding [Label_OK].Value, Source={StaticResource Loc}}"
                        Command="{Binding ConfirmSaveAsCustomCommand}"
                        Classes="primary"
                        Padding="12,4"/>
                <Button Content="{Binding [Label_Cancel].Value, Source={StaticResource Loc}}"
                        Command="{Binding CancelSaveAsCustomCommand}"
                        Padding="12,4"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="{Binding [Label_SaveAsCustom].Value, Source={StaticResource Loc}}"
                    Command="{Binding BeginSaveAsCustomCommand}"
                    Padding="16,6"
                    HorizontalAlignment="Left"/>
            <Button Content="{Binding [Label_Cancel].Value, Source={StaticResource Loc}}"
                    Command="{Binding CancelCommand}"
                    Padding="16,6"/>
            <Button Content="{Binding [Label_Save].Value, Source={StaticResource Loc}}"
                    Command="{Binding SaveCommand}"
                    Classes="primary"
                    Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
