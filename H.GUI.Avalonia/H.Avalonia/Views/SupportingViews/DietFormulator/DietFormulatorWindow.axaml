<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:H.Avalonia.ViewModels.SupportingViews.DietFormulator"
        xmlns:infrastructure="clr-namespace:H.Infrastructure.Controls.ValueConverters;assembly=H.Infrastructure"
        mc:Ignorable="d"
        d:DesignWidth="1200" d:DesignHeight="700"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="500"
        Title="{Binding [Label_DietFormulator].Value, Source={StaticResource Loc}}"
        WindowStartupLocation="CenterOwner"
        x:Class="H.Avalonia.Views.SupportingViews.DietFormulator.DietFormulatorWindow">

    <Window.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{Binding [Label_DietFormulator].Value, Source={StaticResource Loc}}"
                       FontSize="{StaticResource GcdsFontSizeH4}"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding AnimalType, Converter={StaticResource EnumDescriptionConverter}, StringFormat='Scope: {0}'}"
                       FontSize="{StaticResource GcdsFontSizeSmall}"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
        </StackPanel>

        <!-- Three-grid layout: MyDiets (top-left), AvailableIngredients (bottom-left), SelectedDietIngredients (right) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,8,2*" RowDefinitions="*,8,*">

            <!-- ── MY DIETS (top-left) ── -->
            <Border Grid.Row="0" Grid.RowSpan="1" Grid.Column="0"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding [Label_Diets].Value, Source={StaticResource Loc}}"
                               FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}" Padding="10,8"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding MyDiets}"
                              SelectedItem="{Binding SelectedDiet}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="{Binding [Label_DietType].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding DietType, Converter={StaticResource EnumDescriptionConverter}}"
                                                Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── AVAILABLE INGREDIENTS (bottom-left) ── -->
            <Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding [Label_AvailableIngredients].Value, Source={StaticResource Loc}}"
                               FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}" Padding="10,8"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AvailableIngredients}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding IngredientType, Converter={StaticResource EnumDescriptionConverter}}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{Binding [Label_CrudeProtein].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding CrudeProtein, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                            <DataGridTextColumn Header="{Binding [Label_TotalDigestibleNutrient].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── SELECTED DIET INGREDIENTS (right, full height) ── -->
            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource GcdsBgLightBrush}">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="2" Margin="10,8">
                        <TextBlock Text="{Binding [Label_SelectedDietIngredients].Value, Source={StaticResource Loc}}"
                                   FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeBody}"/>
                        <TextBlock Text="{Binding SelectedDiet.Name}"
                                   FontSize="{StaticResource GcdsFontSizeSmall}"
                                   Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedDietIngredients}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [Label_Name].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding IngredientType, Converter={StaticResource EnumDescriptionConverter}}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{Binding [Label_PercentageInDiet].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding PercentageInDiet, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                            <DataGridTextColumn Header="{Binding [Label_CrudeProtein].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding CrudeProtein, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                            <DataGridTextColumn Header="{Binding [Label_TotalDigestibleNutrient].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding TotalDigestibleNutrient, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                            <DataGridTextColumn Header="{Binding [Label_Forage].Value, Source={StaticResource Loc}}"
                                                Binding="{Binding Forage, StringFormat='{}{0:F1}'}"
                                                Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="{Binding [Label_Close].Value, Source={StaticResource Loc}}"
                    Command="{Binding CloseCommand}"
                    Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
