<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           mc:Ignorable="d"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.DairyLifecycleVisualizationView">

<UserControl.Resources>
  <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
  <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
</UserControl.Resources>

  <Border BorderBrush="{StaticResource GcdsBorderLightBrush}"
          BorderThickness="2"
          CornerRadius="8"
          Background="White"
          Padding="20">
    <Grid RowDefinitions="Auto,*,Auto,Auto">
      
      <!-- Title -->
      <StackPanel Grid.Row="0" Margin="0,0,0,24">
        <TextBlock Text="Dairy Cattle Lifecycle" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Understanding the journey from birth to productive milking cow" 
                   FontSize="13" 
                   Foreground="{StaticResource GcdsTextSecondaryBrush}" 
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Main Lifecycle Visualization -->
      <Canvas Grid.Row="1" 
              Width="1000"
              Height="350"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

        <!-- Stage 1: Calf (Birth to 4 months) -->
        <Border Canvas.Left="25" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="{StaticResource GcdsSelectionBgBrush}" 
                BorderBrush="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderBrushConverter}}" 
                BorderThickness="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="12"
                Padding="16"
                Cursor="Hand"
                PointerPressed="Calf_PointerPressed">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CALF" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#1976D2"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Birth - 4 months" 
                       FontSize="11" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Milk &amp; Starter Feed" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 1: Calf to Heifer -->
        <Path Canvas.Left="205"
              Canvas.Top="170"
              Stroke="#424242"
              StrokeThickness="3"
              Data="M 0,0 L 70,0 M 65,-5 L 70,0 L 65,5"/>
        <TextBlock Canvas.Left="215"
                   Canvas.Top="150"
                   Text="Weaning"
                   FontSize="10"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   FontStyle="Italic"/>

        <!-- Stage 2: Heifer (4 months to First Calving ~24 months) -->
        <Border Canvas.Left="275" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="#F3E5F5" 
                BorderBrush="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderBrushConverter}}" 
                BorderThickness="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="12"
                Padding="16"
                Cursor="Hand"
                PointerPressed="Heifer_PointerPressed">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="HEIFER" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#7B1FA2"
                       Margin="0,0,0,8"/>
            <TextBlock Text="4 mo - First Calving" 
                       FontSize="11" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Growing Phase" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 2: Heifer to Lactating (straight horizontal) -->
        <Path Canvas.Left="455"
              Canvas.Top="170"
              Stroke="#424242"
              StrokeThickness="3"
              Data="M 0,0 L 70,0 M 65,-5 L 70,0 L 65,5"/>
        <TextBlock Canvas.Left="458"
                   Canvas.Top="150"
                   Text="First Calving"
                   FontSize="10"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   FontWeight="Bold"/>

        <!-- Stage 3: Lactating Cow (Producing Milk) -->
        <Border Canvas.Left="525" 
                Canvas.Top="100"
                Width="200" 
                Height="140"
                Background="#E8F5E9" 
                BorderBrush="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderBrushConverter}}" 
                BorderThickness="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="12"
                Padding="16"
                Cursor="Hand"
                PointerPressed="Lactating_PointerPressed">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="LACTATING COW" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#388E3C"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Milk Production" 
                       FontSize="11" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="~305 days lactation" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 3: Lactating to Dry (straight horizontal) -->
        <Path Canvas.Left="725"
              Canvas.Top="170"
              Stroke="#424242"
              StrokeThickness="3"
              Data="M 0,0 L 70,0 M 65,-5 L 70,0 L 65,5"/>
        <TextBlock Canvas.Left="730"
                   Canvas.Top="150"
                   Text="Drying Off"
                   FontSize="10"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   FontWeight="Bold"/>

        <!-- Stage 4: Dry Cow (Pre-Calving Rest) -->
        <Border Canvas.Left="795" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="#FFF3E0" 
                BorderBrush="{Binding IsDrySelected, Converter={StaticResource BoolToBorderBrushConverter}}" 
                BorderThickness="{Binding IsDrySelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="12"
                Padding="16"
                Cursor="Hand"
                PointerPressed="Dry_PointerPressed">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="DRY COW" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#F57C00"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Pre-Calving Rest" 
                       FontSize="11" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="~60 days" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 4: Dry back to Lactating (curved up - completing the cycle) -->
        <!-- Arc curve only (dashed): from Dry left (795) to Lactating right (725) -->
        <Path Canvas.Left="720"
              Canvas.Top="95"
              Stroke="#424242"
              StrokeThickness="3"
              StrokeDashArray="4,2"
              Data="M 75,5 Q 37,-45 0,5"/>
        <!-- Arrowhead pointing left at Lactating right edge (solid, no dash) -->
        <Path Canvas.Left="720"
              Canvas.Top="95"
              Stroke="#424242"
              StrokeThickness="3"
              Data="M 8,0 L 0,5 L 8,10"/>
        <TextBlock Canvas.Left="645"
                   Canvas.Top="35"
                   Text="CALVING - Cycle Repeats"
                   FontSize="11"
                   Foreground="#D32F2F"
                   FontWeight="Bold"/>

        <!-- Culling/Replacement Arrow from Lactating down -->
        <Path Canvas.Left="625" 
              Canvas.Top="245"
              Stroke="#D32F2F" 
              StrokeThickness="2"
              StrokeDashArray="3,2"
              Data="M 0,0 L 0,50 M -5,45 L 0,50 L 5,45"/>
        <Border Canvas.Left="545"
                Canvas.Top="300"
                Width="160"
                Background="#FFEBEE"
                BorderBrush="{Binding IsCullingSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                BorderThickness="{Binding IsCullingSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="6"
                Padding="12,8"
                Cursor="Hand"
                PointerPressed="Culling_PointerPressed">
          <StackPanel>
            <TextBlock Text="CULLING" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="#D32F2F"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Based on replacement rate" 
                       FontSize="9" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Replacement Arrow from Heifer up to replace culled -->
        <Path Canvas.Left="365"
              Canvas.Top="245"
              Stroke="#2E7D32"
              StrokeThickness="2"
              StrokeDashArray="3,2"
              Data="M 0,0 L 0,50 M -5,45 L 0,50 L 5,45"/>
        <Border Canvas.Left="285"
                Canvas.Top="300"
                Width="160"
                Background="#E8F5E9"
                BorderBrush="{Binding IsReplacementSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                BorderThickness="{Binding IsReplacementSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                CornerRadius="6"
                Padding="12,8"
                Cursor="Hand"
                PointerPressed="Replacement_PointerPressed">
          <StackPanel>
            <TextBlock Text="REPLACEMENT" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="#2E7D32"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Heifers enter herd" 
                       FontSize="9" 
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

      </Canvas>

      <!-- Stage Information Box (appears when a stage is selected) -->
      <Border Grid.Row="2"
              Background="{StaticResource GcdsBgLightBrush}"
              BorderBrush="{StaticResource GcdsBorderLightBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="16"
              Margin="0,16,0,16"
              IsVisible="{Binding HasSelection}">
        <StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding SelectedStageTitle}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
            <Button Grid.Column="1"
                    Content="X"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Foreground="#999"
                    Cursor="Hand"
                    Click="CloseInfo_Click"
                    Padding="8,0"/>
          </Grid>
          <TextBlock Text="{Binding SelectedStageDescription}"
                     TextWrapping="Wrap"
                     FontSize="12"
                     Foreground="{StaticResource GcdsTextSecondaryBrush}"
                     LineHeight="18"
                     Margin="0,8,0,0"/>
        </StackPanel>
      </Border>
      
    </Grid>
  </Border>

</UserControl>
