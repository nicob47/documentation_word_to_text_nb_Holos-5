<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
           xmlns:dairyVm="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Dairy"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           mc:Ignorable="d" d:DesignWidth="900"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.CalculatedHerdCompositionView">

<Design.DataContext>
  <dairyVm:DairyComponentViewModelDesign/>
</Design.DataContext>

<UserControl.Resources>
  <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
  <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
  <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
  <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
</UserControl.Resources>

<!-- Parent container for Steps 1 and 2 -->
<StackPanel>

  <!-- Step 1: Select a Stage -->
  <Border x:Name="MainContainerBorder"
          Classes="step-container"
          Background="#E8F5E9"
          BorderBrush="#43A047"
          Margin="0,0,0,20">
    <StackPanel x:Name="MainStackPanel">
      <!-- Step Header -->
      <StackPanel x:Name="StepHeaderStackPanel"
                  Classes="step-header"
                  Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
        <!-- Step Badge -->
        <Border Classes="step-badge" VerticalAlignment="Top">
          <TextBlock Text="{Binding [Label_StepOne].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
        </Border>

        <StackPanel VerticalAlignment="Center">
          <!-- Title -->
          <TextBlock x:Name="HeaderTitleTextBlock"
                     Text="{Binding [Label_DefineSteadyStateHerdComposition].Value, Source={StaticResource Loc}}"
                     Classes="step-number-description"/>

          <!-- Description -->
          <TextBlock x:Name="HeaderDescriptionTextBlock"
                     Text="{Binding [Label_ClickStageCardBelowDesc].Value, Source={StaticResource Loc}}"
                     FontSize="13"
                     Foreground="{StaticResource GcdsTextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- Main Content with Cards and Calculations -->
      <StackPanel x:Name="MainContentStackPanel">
        <!-- Stage Cards Row with Integrated Calculations -->
        <Grid x:Name="StageCardsGrid"
              ColumnDefinitions="*,*,*,*,Auto">
          <!-- Calves -->
          <Border Grid.Column="0"
                  x:Name="CalfStageBorder"
                  Background="{Binding IsCalfSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                  BorderBrush="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                  BorderThickness="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                  CornerRadius="8"
                  Padding="12"
                  Margin="4"
                  Cursor="Hand"
                  PointerPressed="OnCalfCardClick">
            <StackPanel x:Name="CalfContentStackPanel">
              <!-- Header with Title -->
              <TextBlock x:Name="CalfTitleTextBlock"
                         Text="{Binding [Label_Calf].Value, Source={StaticResource Loc}}"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="#1976D2"
                         HorizontalAlignment="Center"
                         Margin="0,4,0,8"/>

              <!-- Display Values -->
              <StackPanel HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                  <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0}'}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1976D2"/>
                  <Run Text="{Binding [Label_AnimalsUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                  <Run Text="{Binding SelectedDairyComponentDto.CalfStageDurationDays, StringFormat='{}{0}'}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#1976D2"/>
                  <Run Text="{Binding [Label_DaysUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>


          <!-- Heifers -->
          <Border Grid.Column="1"
                  x:Name="HeiferStageBorder"
                  Background="{Binding IsHeiferSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                  BorderBrush="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                  BorderThickness="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                  CornerRadius="8"
                  Padding="12"
                  Margin="4"
                  Cursor="Hand"
                  PointerPressed="OnHeiferCardClick">
            <StackPanel x:Name="HeiferContentStackPanel">
              <!-- Header with Title -->
              <TextBlock x:Name="HeiferTitleTextBlock"
                         Text="{Binding [Label_Heifer].Value, Source={StaticResource Loc}}"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="#7B1FA2"
                         HorizontalAlignment="Center"
                         Margin="0,4,0,8"/>

              <!-- Display Values -->
              <StackPanel HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                  <Run Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0}'}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#7B1FA2"/>
                  <Run Text="{Binding [Label_AnimalsUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                  <Run Text="{Binding SelectedDairyComponentDto.HeiferStageDurationDays, StringFormat='{}{0}'}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#7B1FA2"/>
                  <Run Text="{Binding [Label_DaysUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Lactating -->
          <Border Grid.Column="2"
                  x:Name="LactatingStageBorder"
                  Background="{Binding IsLactatingSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                  BorderBrush="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                  BorderThickness="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                  CornerRadius="8"
                  Padding="12"
                  Margin="4"
                  Cursor="Hand"
                  PointerPressed="OnLactatingCardClick">
            <StackPanel x:Name="LactatingContentStackPanel">
              <!-- Header with Title -->
              <TextBlock x:Name="LactatingTitleTextBlock"
                         Text="{Binding [Label_Lactating].Value, Source={StaticResource Loc}}"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="#388E3C"
                         HorizontalAlignment="Center"
                         Margin="0,4,0,8"/>

              <!-- Display Values -->
              <StackPanel HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                  <Run Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0}'}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#388E3C"/>
                  <Run Text="{Binding [Label_AnimalsUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                  <Run Text="{Binding SelectedDairyComponentDto.LactationDurationDays, StringFormat='{}{0}'}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#388E3C"/>
                  <Run Text="{Binding [Label_DaysUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>


          <!-- Dry -->
          <Border Grid.Column="3"
                  x:Name="DryStageBorder"
                  Background="{Binding IsDrySelected, Converter={StaticResource BoolToBackgroundConverter}}"
                  BorderBrush="{Binding IsDrySelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                  BorderThickness="{Binding IsDrySelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                  CornerRadius="8"
                  Padding="12"
                  Margin="4"
                  Cursor="Hand"
                  PointerPressed="OnDryCardClick">
            <StackPanel x:Name="DryContentStackPanel">
              <!-- Header with Title -->
              <TextBlock x:Name="DryTitleTextBlock"
                         Text="{Binding [Label_Dry].Value, Source={StaticResource Loc}}"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="#F57C00"
                         HorizontalAlignment="Center"
                         Margin="0,4,0,8"/>

              <!-- Display Values -->
              <StackPanel HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                  <Run Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0}'}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#F57C00"/>
                  <Run Text="{Binding [Label_AnimalsUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                  <Run Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0}'}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#F57C00"/>
                  <Run Text="{Binding [Label_DaysUnit].Value, Source={StaticResource Loc}}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Total -->
          <Border x:Name="TotalBorder"
                  Grid.Column="4"
                  Background="#43A047"
                  CornerRadius="8"
                  Padding="16"
                  Margin="4"
                  VerticalAlignment="Stretch">
            <StackPanel x:Name="TotalContentStackPanel"
                        VerticalAlignment="Center">
              <TextBlock x:Name="TotalTitleTextBlock"
                         Text="{Binding [Label_Total].Value, Source={StaticResource Loc}}"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,4"/>
              <TextBlock x:Name="TotalCountTextBlockk06"
                         Text="{Binding SelectedDairyComponentDto.TotalSteadyStateHerdSize, StringFormat='{}{0}'}"
                         FontSize="24"
                         FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,2"/>
              <TextBlock x:Name="TotalLabelTextBlock"
                         Text="{Binding [Label_Animals].Value, Source={StaticResource Loc}}"
                         FontSize="10"
                         Foreground="White"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </StackPanel>
  </Border>

  <!-- Step 2: Population and Duration Configuration (shows when a stage is selected) -->
  <Border Classes="step-container"
          Background="{StaticResource GcdsWarningBgBrush}"
          BorderBrush="#FFA726"
          Margin="0,0,0,20"
          IsVisible="{Binding IsAnyStageSelected}">
    <StackPanel Grid.IsSharedSizeScope="True">
      <!-- Step Header -->
      <StackPanel Orientation="Horizontal" Classes="step-header" Spacing="12" Margin="0,0,0,12">
        <!-- Step Badge -->
        <Border Classes="step-badge" VerticalAlignment="Top">
          <TextBlock Text="{Binding [Label_StepTwo].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
        </Border>

        <StackPanel VerticalAlignment="Center">
          <!-- Title -->
          <TextBlock Text="{Binding [Label_ConfigureStagePoplAndDuration].Value, Source={StaticResource Loc}}"
                     Classes="step-number-description"/>

          <!-- Description -->
          <TextBlock Text="{Binding [Label_EnterSteadyStatePopDesc].Value, Source={StaticResource Loc}}"
                     FontSize="13"
                     Foreground="{StaticResource GcdsTextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- Mode Toggle -->
      <StackPanel Margin="0,20,0,20">
        <TextBlock Text="{Binding [Label_HowManyAnimalGroups].Value, Source={StaticResource Loc}}"
                   Classes="section-heading"/>
        <StackPanel Orientation="Horizontal">
          <RadioButton Content="{Binding [Label_ASingleAnimalGroup].Value, Source={StaticResource Loc}}"
                       IsChecked="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode, Converter={StaticResource InverseBooleanConverter}}"
                       GroupName="PopulationMode"
                       Margin="0,0,20,0"/>
          <RadioButton Content="{Binding [Label_MultipleGroups].Value, Source={StaticResource Loc}}"
                       IsChecked="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode}"
                       GroupName="PopulationMode"/>
        </StackPanel>
      </StackPanel>

      <!-- Input Controls for Each Stage -->
      <StackPanel Margin="0,0,0,0">

        <!-- ====== CALF STAGE ====== -->
        <StackPanel IsVisible="{Binding IsCalfSelected}"
                    Margin="0,0,0,20">

          <!-- Days in Stage (Common to both modes) -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding [Label_HowLongCalvesRemain].Value, Source={StaticResource Loc}}"
                         Classes="input-label-text"
                         Margin="0,0,8,0"/>
              <NumericUpDown Grid.Column="1"
                             Value="{Binding SelectedDairyComponentDto.CalfStageDurationDays}"
                             Minimum="30" Maximum="365"
                             FormatString="0" Increment="5"
                             Margin="8,0"
                             HorizontalAlignment="Stretch"/>
              <TextBlock Grid.Column="2" Text="{Binding [Label_Days].Value, Source={StaticResource Loc}}"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- SIMPLE MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode, Converter={StaticResource InverseBooleanConverter}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                  <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
                </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding [Label_HowManyCalvesInHerd].Value, Source={StaticResource Loc}}"
                             Classes="input-label-text"
                             Margin="0,0,8,0"/>
                  <NumericUpDown Grid.Column="1"
                                 Value="{Binding SelectedDairyComponentDto.SteadyStateCalves}"
                                 Minimum="0" Maximum="10000"
                                 FormatString="0" Increment="1"
                                 Margin="8,0"
                                 HorizontalAlignment="Stretch"/>
                  <TextBlock Grid.Column="2" Text="{Binding [Label_Head].Value, Source={StaticResource Loc}}"
                             VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>

              <!-- ADVANCED MODE -->
              <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode}">
                <TextBlock Text="{Binding [Label_AnimalGroupsHeader].Value, Source={StaticResource Loc}}"
                           Classes="section-heading"/>

                <!-- Helpful explanation -->
                <TextBlock Text="{Binding [Label_MultipleGroupsExplanation].Value, Source={StaticResource Loc}}"
                           TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                           FontStyle="Italic" Margin="0,0,0,12" LineHeight="18"/>

                <!-- Groups List -->
                <StackPanel IsVisible="{Binding SelectedDairyComponentDto.CalfPopulationGroups.Count}"
                            Margin="0,0,0,12">
                  <!-- Instruction text -->
                  <TextBlock Text="{Binding [Label_EnterGroupNameDesc].Value, Source={StaticResource Loc}}"
                             TextWrapping="Wrap" FontSize="11" Foreground="#888"
                             FontStyle="Italic" Margin="0,0,0,12"/>

                  <!-- Header Row -->
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="250"/>
                      <ColumnDefinition Width="120"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding [Label_GroupName].Value, Source={StaticResource Loc}}"
                               FontWeight="Medium" FontSize="11"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding [Label_AnimalsColumn].Value, Source={StaticResource Loc}}"
                               FontWeight="Medium" FontSize="11"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding [Label_Actions].Value, Source={StaticResource Loc}}"
                               FontWeight="Medium" FontSize="11"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  </Grid>

                  <!-- Groups ItemsControl -->
                  <ItemsControl ItemsSource="{Binding SelectedDairyComponentDto.CalfPopulationGroups}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,4">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>

                          <!-- Group Name TextBox -->
                          <TextBox Grid.Column="0"
                                   Text="{Binding GroupName}"
                                   Watermark="{Binding [Label_EnterGroupNameWatermark].Value, Source={StaticResource Loc}}"
                                   Margin="0,0,8,0"/>

                          <!-- Animals NumericUpDown -->
                          <NumericUpDown Grid.Column="1"
                                         Value="{Binding NumberOfAnimals}"
                                         Minimum="0" Maximum="10000"
                                         FormatString="0" Increment="1"
                                         Margin="0,0,8,0"/>

                          <!-- Delete Button -->
                          <Button Grid.Column="2"
                                  Command="{Binding $parent[ItemsControl].((dairyVm:DairyComponentViewModel)DataContext).RemoveGroupCommand}"
                                  CommandParameter="{Binding}"
                                  Background="Transparent"
                                  ToolTip.Tip="{Binding [Tooltip_RemoveGroup].Value, Source={StaticResource Loc}}"
                                  Padding="4">
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                  Fill="Red" Width="16" Height="16" Stretch="Uniform"/>
                          </Button>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                  <!-- Add Group Button -->
                  <Button Content="{Binding [Button_AddNewGroup].Value, Source={StaticResource Loc}}"
                          Command="{Binding AddCalfGroupCommand}"
                          HorizontalAlignment="Left"
                          Margin="0,12,0,0"
                          Classes="accent"/>
                </StackPanel>
              </StackPanel>

        <!-- ====== HEIFER STAGE ====== -->
        <StackPanel IsVisible="{Binding IsHeiferSelected}"
                    Margin="0,0,0,20">

          <!-- Days in Stage -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding [Label_HowLongHeifersRemain].Value, Source={StaticResource Loc}}"
                         Classes="input-label-text"
                         Margin="0,0,8,0"/>
              <NumericUpDown Grid.Column="1"
                             Value="{Binding SelectedDairyComponentDto.HeiferStageDurationDays}"
                             Minimum="365" Maximum="1095"
                             FormatString="0" Increment="10"
                             HorizontalAlignment="Stretch"/>
              <TextBlock Grid.Column="2" Text="{Binding [Label_Days].Value, Source={StaticResource Loc}}"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- SIMPLE MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode, Converter={StaticResource InverseBooleanConverter}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto" MinWidth="120"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding [Label_HowManyHeifersInHerd].Value, Source={StaticResource Loc}}"
                           Classes="input-label-text"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1"
                               Value="{Binding SelectedDairyComponentDto.SteadyStateHeifers}"
                               Minimum="0" Maximum="10000"
                               FormatString="0" Increment="1"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Head].Value, Source={StaticResource Loc}}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>

            <!-- ADVANCED MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode}">
              <TextBlock Text="{Binding [Label_AnimalGroupsHeader].Value, Source={StaticResource Loc}}"
                         Classes="section-heading"/>

              <!-- Helpful explanation -->
              <TextBlock Text="{Binding [Label_MultipleGroupsExplanation].Value, Source={StaticResource Loc}}"
                         TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                         FontStyle="Italic" Margin="0,0,0,12" LineHeight="18"/>

              <StackPanel IsVisible="{Binding SelectedDairyComponentDto.HeiferPopulationGroups.Count}"
                          Margin="0,0,0,12">
                <!-- Instruction text -->
                <TextBlock Text="{Binding [Label_EnterGroupNameDesc].Value, Source={StaticResource Loc}}"
                           TextWrapping="Wrap" FontSize="11" Foreground="#888"
                           FontStyle="Italic" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding [Label_GroupName].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding [Label_AnimalsColumn].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="2" Text="{Binding [Label_Actions].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding SelectedDairyComponentDto.HeiferPopulationGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="250"/>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding GroupName}"
                                 Watermark="{Binding [Label_EnterGroupNameWatermark].Value, Source={StaticResource Loc}}"
                                 Margin="0,0,8,0"/>

                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding NumberOfAnimals}"
                                       Minimum="0" Maximum="10000"
                                       FormatString="0" Increment="1"
                                       Margin="0,0,8,0"/>

                        <Button Grid.Column="2"
                                Command="{Binding $parent[ItemsControl].((dairyVm:DairyComponentViewModel)DataContext).RemoveGroupCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                ToolTip.Tip="{Binding [Tooltip_RemoveGroup].Value, Source={StaticResource Loc}}"
                                Padding="4">
                          <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                Fill="Red" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <Button Content="{Binding [Button_AddNewGroup].Value, Source={StaticResource Loc}}"
                      Command="{Binding AddHeiferGroupCommand}"
                      HorizontalAlignment="Left"
                      Margin="0,12,0,0"
                      Classes="accent"/>
            </StackPanel>
        </StackPanel>

        <!-- ====== LACTATING STAGE ====== -->
        <StackPanel IsVisible="{Binding IsLactatingSelected}"
                    Margin="0,0,0,20">

          <!-- Days in Stage -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding [Label_HowLongLactationPeriod].Value, Source={StaticResource Loc}}"
                         Classes="input-label-text"
                         Margin="0,0,8,0"/>
              <NumericUpDown Grid.Column="1"
                             Value="{Binding SelectedDairyComponentDto.LactationDurationDays}"
                             Minimum="200" Maximum="400"
                             FormatString="0" Increment="5"
                             HorizontalAlignment="Stretch"/>
              <TextBlock Grid.Column="2" Text="{Binding [Label_Days].Value, Source={StaticResource Loc}}"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- SIMPLE MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode, Converter={StaticResource InverseBooleanConverter}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto" MinWidth="120"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding [Label_HowManyLactatingCowsInHerd].Value, Source={StaticResource Loc}}"
                           Classes="input-label-text"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1"
                               Value="{Binding SelectedDairyComponentDto.SteadyStateLactating}"
                               Minimum="0" Maximum="10000"
                               FormatString="0" Increment="1"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Head].Value, Source={StaticResource Loc}}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>

            <!-- ADVANCED MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode}">
              <TextBlock Text="{Binding [Label_AnimalGroupsHeader].Value, Source={StaticResource Loc}}"
                         Classes="section-heading"/>

              <!-- Helpful explanation -->
              <TextBlock Text="{Binding [Label_MultipleGroupsExplanation].Value, Source={StaticResource Loc}}"
                         TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                         FontStyle="Italic" Margin="0,0,0,12" LineHeight="18"/>

              <StackPanel IsVisible="{Binding SelectedDairyComponentDto.LactatingPopulationGroups.Count}"
                          Margin="0,0,0,12">
                <!-- Instruction text -->
                <TextBlock Text="{Binding [Label_EnterGroupNameDesc].Value, Source={StaticResource Loc}}"
                           TextWrapping="Wrap" FontSize="11" Foreground="#888"
                           FontStyle="Italic" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding [Label_GroupName].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding [Label_AnimalsColumn].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="2" Text="{Binding [Label_Actions].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding SelectedDairyComponentDto.LactatingPopulationGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="250"/>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding GroupName}"
                                 Watermark="{Binding [Label_EnterGroupNameWatermark].Value, Source={StaticResource Loc}}"
                                 Margin="0,0,8,0"/>

                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding NumberOfAnimals}"
                                       Minimum="0" Maximum="10000"
                                       FormatString="0" Increment="1"
                                       Margin="0,0,8,0"/>

                        <Button Grid.Column="2"
                                Command="{Binding $parent[ItemsControl].((dairyVm:DairyComponentViewModel)DataContext).RemoveGroupCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                ToolTip.Tip="{Binding [Tooltip_RemoveGroup].Value, Source={StaticResource Loc}}"
                                Padding="4">
                          <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                Fill="Red" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <Button Content="{Binding [Button_AddNewGroup].Value, Source={StaticResource Loc}}"
                      Command="{Binding AddLactatingGroupCommand}"
                      HorizontalAlignment="Left"
                      Margin="0,12,0,0"
                      Classes="accent"/>
            </StackPanel>
        </StackPanel>

        <!-- ====== DRY STAGE ====== -->
        <StackPanel IsVisible="{Binding IsDrySelected}"
                    Margin="0,0,0,20">

          <!-- Days in Stage -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding [Label_HowLongDryPeriod].Value, Source={StaticResource Loc}}"
                         Classes="input-label-text"
                         Margin="0,0,8,0"/>
              <NumericUpDown Grid.Column="1"
                             Value="{Binding SelectedDairyComponentDto.DryPeriodDays}"
                             Minimum="0" Maximum="120"
                             FormatString="0" Increment="5"
                             HorizontalAlignment="Stretch"/>
              <TextBlock Grid.Column="2" Text="{Binding [Label_Days].Value, Source={StaticResource Loc}}"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- SIMPLE MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode, Converter={StaticResource InverseBooleanConverter}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto" MinWidth="120"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding [Label_HowManyDryCowsInHerd].Value, Source={StaticResource Loc}}"
                           Classes="input-label-text"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1"
                               Value="{Binding SelectedDairyComponentDto.SteadyStateDry}"
                               Minimum="0" Maximum="10000"
                               FormatString="0" Increment="1"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Head].Value, Source={StaticResource Loc}}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>

            <!-- ADVANCED MODE -->
            <StackPanel IsVisible="{Binding SelectedDairyComponentDto.UseAdvancedPopulationMode}">
              <TextBlock Text="{Binding [Label_AnimalGroupsHeader].Value, Source={StaticResource Loc}}"
                         Classes="section-heading"/>

              <!-- Helpful explanation -->
              <TextBlock Text="{Binding [Label_MultipleGroupsExplanation].Value, Source={StaticResource Loc}}"
                         TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                         FontStyle="Italic" Margin="0,0,0,12" LineHeight="18"/>

              <StackPanel IsVisible="{Binding SelectedDairyComponentDto.DryPopulationGroups.Count}"
                          Margin="0,0,0,12">
                <!-- Instruction text -->
                <TextBlock Text="{Binding [Label_EnterGroupNameDesc].Value, Source={StaticResource Loc}}"
                           TextWrapping="Wrap" FontSize="11" Foreground="#888"
                           FontStyle="Italic" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding [Label_GroupName].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding [Label_AnimalsColumn].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="2" Text="{Binding [Label_Actions].Value, Source={StaticResource Loc}}"
                             FontWeight="Medium" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding SelectedDairyComponentDto.DryPopulationGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="250"/>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding GroupName}"
                                 Watermark="{Binding [Label_EnterGroupNameWatermark].Value, Source={StaticResource Loc}}"
                                 Margin="0,0,8,0"/>

                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding NumberOfAnimals}"
                                       Minimum="0" Maximum="10000"
                                       FormatString="0" Increment="1"
                                       Margin="0,0,8,0"/>

                        <Button Grid.Column="2"
                                Command="{Binding $parent[ItemsControl].((dairyVm:DairyComponentViewModel)DataContext).RemoveGroupCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                ToolTip.Tip="{Binding [Tooltip_RemoveGroup].Value, Source={StaticResource Loc}}"
                                Padding="4">
                          <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                Fill="Red" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <Button Content="{Binding [Button_AddNewGroup].Value, Source={StaticResource Loc}}"
                      Command="{Binding AddDryGroupCommand}"
                      HorizontalAlignment="Left"
                      Margin="0,12,0,0"
                      Classes="accent"/>
            </StackPanel>
        </StackPanel>

      </StackPanel>
    </StackPanel>
  </Border>

</StackPanel>

</UserControl>
