<UserControl xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
xmlns:dairyVm="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Dairy"
xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
mc:Ignorable="d" d:DesignWidth="1400"
x:Class="H.Avalonia.Views.ComponentViews.Dairy.DairyComponentView">
  
  <Design.DataContext>
    <dairyVm:DairyComponentViewModelDesign/>
  </Design.DataContext>
  
  <Grid>
    <Grid.RowDefinitions>
      <!-- Title -->
      <RowDefinition Height="Auto"/>
      <!-- Content -->
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <!-- Title -->
      <TextBox Classes="view-title" Text="{Binding Path=SelectedDairyComponentDto.Name}"/>
      <Border Classes="title-underline"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" 
                  VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="{StaticResource DefaultUserControlMargin}">

            <!-- Lifecycle Visualization - Educational Diagram (Advanced Options Only) -->
      <dairy:DairyLifecycleVisualizationView Margin="0,0,0,24"
                                              IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=dairy:DairyComponentView}}"/>

      <!-- Step 1: Select Stage & Step 2: Configure Population/Duration (CalculatedHerdCompositionView contains both) -->
      <dairy:CalculatedHerdCompositionView Margin="0,0,0,20"/>

      <!-- Step 3: Management Practices Configuration - Only show when a stage card is selected -->
      <dairy:LifecycleConfigurationView Margin="0,0,0,16"
                                        IsVisible="{Binding IsAnyStageSelected}"/>

      </StackPanel>
    </ScrollViewer>
  </Grid>
  
</UserControl>
