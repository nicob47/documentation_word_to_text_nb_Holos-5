<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:animals="clr-namespace:H.Avalonia.Views.ComponentViews.Animals"
			 xmlns:beef="clr-namespace:H.Avalonia.Views.ComponentViews.Beef"
			 xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.Beef.CowCalfComponentView">

	<Design.DataContext>
        <componentViews:AnimalComponentViewModelDesign/>
	</Design.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Auto"
				 HorizontalScrollBarVisibility="Disabled">
		<StackPanel>
			<beef:BeefLifecycleVisualizationView/>
			<animals:AnimalsComponentsView/>
		</StackPanel>
	</ScrollViewer>

</UserControl>
