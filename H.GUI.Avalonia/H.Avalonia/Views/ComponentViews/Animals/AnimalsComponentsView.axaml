<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:animals="clr-namespace:H.Avalonia.Views.ComponentViews.Animals"
             xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.Animals.AnimalsComponentsView">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Title -->
            <TextBox Classes="view-title" Text="{Binding Path=SelectedAnimalComponentDto.Name}"/>
            <Border Classes="title-underline"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="{StaticResource DefaultUserControlMargin}">

                <!-- Step 1: Define Animal Groups -->
                <animals:AnimalsStep1View Margin="0,0,0,20"/>

                <!-- Step 2: Management Periods (for selected group) -->
                <animals:AnimalsStep2View Margin="0,0,0,20"/>

                <!-- Step 3: Management Practices Configuration -->
                <animals:AnimalsStep3View Margin="0,0,0,16"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
