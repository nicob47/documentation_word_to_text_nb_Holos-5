<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
             xmlns:animals="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Animals"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.Animals.AnimalsStep2View">

    <Design.DataContext>
        <animals:AnimalsViewModelDesign/>
    </Design.DataContext>

    <Border Classes="step-container" Margin="0,0,0,16" IsVisible="{Binding IsGroupSelected}">
        <StackPanel>

            <StackPanel Classes="step-header" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <!-- Step Badge -->
                <Border Classes="step-badge" VerticalAlignment="Top">
                    <TextBlock Text="{Binding [Label_Step2].Value, Source={StaticResource Loc}}" Classes="step-badge-text" />
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <!-- Step Description -->
                    <TextBlock Text="{Binding [Label_Step2Text].Value, Source={StaticResource Loc}}"
                               Classes="step-number-description" />
                </StackPanel>
            </StackPanel>

            <!-- Management Period Instructions -->
            <Border Background="{StaticResource GcdsSelectionBgBrush}"
                    BorderBrush="{StaticResource GcdsBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,10">
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding ManagementPeriodIntroText}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding [Message_ManagementPeriodTipName].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding [Message_ManagementPeriodTipDates].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding [Message_ManagementPeriodTipDays].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding [Message_ManagementPeriodTipAnimals].Value, Source={StaticResource Loc}}"
                               FontSize="{StaticResource GcdsFontSizeSmall}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,10" Spacing="8">
                <Button Command="{Binding AddManagementPracticeCommand}" Classes="add-management-period"
                        Content="{Binding [Button_AddManagementPeriod].Value, Source={StaticResource Loc}}" />
                <Button Command="{Binding RemoveManagementPracticeCommand}"
                        CommandParameter="{Binding SelectedManagementPractice}"
                        IsVisible="{Binding HasManagementPeriods}"
                        VerticalAlignment="Bottom"
                        Classes="delete-button">
                    <TextBlock Classes="delete-text"
                               Text="{Binding [Label_RemoveSelected].Value, Source={StaticResource Loc}}" />
                </Button>
            </StackPanel>

            <DataGrid ItemsSource="{Binding SelectedGroupManagementPeriods}"
                      SelectedItem="{Binding SelectedManagementPractice}"
                      AutoGenerateColumns="False"
                      IsVisible="{Binding HasManagementPeriods}"
                      Margin="10,10,10,0"
                      HorizontalAlignment="Stretch"
                      BorderThickness="1"
                      GridLinesVisibility="All"
                      MinHeight="120"
                      MaxHeight="350"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Header="{Binding [Label_ManagementPeriodName].Value, Source={StaticResource Loc}}" Binding="{Binding Path=Name}"/>
                    <DataGridTemplateColumn Width="Auto" Header="{Binding [Label_StartDate].Value, Source={StaticResource Loc}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CalendarDatePicker SelectedDate="{Binding Start}"
                                                    Watermark="yyyy-MM-dd"
                                                    SelectedDateFormat="Custom"
                                                    CustomDateFormatString="yyyy-MM-dd"
                                                    MinWidth="140"
                                                    HorizontalAlignment="Stretch" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="Auto" Header="{Binding [Label_EndDate].Value, Source={StaticResource Loc}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CalendarDatePicker SelectedDate="{Binding End}"
                                                    Watermark="yyyy-MM-dd"
                                                    SelectedDateFormat="Custom"
                                                    CustomDateFormatString="yyyy-MM-dd"
                                                    MinWidth="140"
                                                    HorizontalAlignment="Stretch" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="Auto" Header="{Binding [Label_NumberOfDays].Value, Source={StaticResource Loc}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <NumericUpDown AutomationProperties.Name="{Binding [Label_NumberOfDays].Value, Source={StaticResource Loc}}"  Value="{Binding NumberOfDays}"
                                               Minimum="1"
                                               Increment="1"
                                               FormatString="{}{0:0}"
                                               ShowButtonSpinner="True"
                                               AllowSpin="True"
                                               MinWidth="140"
                                               HorizontalAlignment="Stretch" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="Auto" Header="{Binding [Label_NumberOfAnimals].Value, Source={StaticResource Loc}}" Binding="{Binding Path=NumberOfAnimals}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Period count indicator — helps the user know total periods when grid is scrollable -->
            <TextBlock IsVisible="{Binding HasManagementPeriods}"
                       Text="{Binding SelectedGroupManagementPeriods.Count, StringFormat='{}{0} management period(s) defined'}"
                       FontSize="12"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       Margin="12,4,10,0"
                       HorizontalAlignment="Left" />

            <!-- Validation Error Summary -->
            <Border IsVisible="{Binding SelectedManagementPractice.HasErrors, FallbackValue=False}"
                    BorderBrush="{StaticResource GcdsDangerBrush}"
                    BorderThickness="1"
                    Background="#FFF5F5"
                    Padding="10"
                    Margin="10,4,10,0"
                    CornerRadius="4">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SelectedManagementPractice.Name, StringFormat='{}{0}:'}"
                               Foreground="{StaticResource GcdsDangerBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedManagementPractice.ValidationSummary}"
                               Foreground="{StaticResource GcdsDangerBrush}"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
