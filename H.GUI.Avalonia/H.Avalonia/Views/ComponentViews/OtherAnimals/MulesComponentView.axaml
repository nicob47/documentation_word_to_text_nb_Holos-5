<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:viewModels="clr-namespace:H.Avalonia.ViewModels.ComponentViews.OtherAnimals"
			 xmlns:viewTemplates="clr-namespace:H.Avalonia"
			 xmlns:animals="clr-namespace:H.Avalonia.Views.ComponentViews.Animals"
			 xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.OtherAnimals.MulesComponentView">

	<Design.DataContext>
        <componentViews:AnimalComponentViewModelDesign/>
	</Design.DataContext>

	<animals:AnimalsComponentsView/>

</UserControl>
