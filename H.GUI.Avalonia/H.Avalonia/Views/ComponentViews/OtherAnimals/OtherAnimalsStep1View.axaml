<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
             xmlns:otherAnimals="clr-namespace:H.Avalonia.ViewModels.ComponentViews.OtherAnimals"
             xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.OtherAnimals.OtherAnimalsStep1View">

    <Design.DataContext>
        <otherAnimals:OtherAnimalsViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>

    <Border Classes="step-container" Margin="0,0,0,16">
        <StackPanel>

            <StackPanel Classes="step-header" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <!-- Step Badge -->
                <Border Classes="step-badge" VerticalAlignment="Top">
                    <TextBlock Text="{Binding [Label_StepOne].Value, Source={StaticResource Loc}}" Classes="step-badge-text" />
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <!-- Step Description -->
                    <TextBlock Text="{Binding [Label_Step1Text].Value, Source={StaticResource Loc}}"
                               Classes="step-number-description" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Command="{Binding AddAnimalGroupDtoCommand}" Classes="add-group" Content="{Binding [Button_AddGroup].Value, Source={StaticResource Loc}}" />
            </StackPanel>

            <!-- Timeline Container -->
            <Border Classes="timeline-container">
                <StackPanel>
                    <!-- Timeline Header -->
                    <TextBlock Text="{Binding [Label_AnimalGroupsTitle].Value, Source={StaticResource Loc}}" Classes="timeline-header" />

                    <!-- Timeline Scrollable Area -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden"
                                  MaxHeight="250"
                                  MinHeight="150">
                        <ItemsControl ItemsSource="{Binding Path=AnimalGroupDtos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="16" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Timeline Card — clicking selects the group -->
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="4"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            Command="{Binding $parent[ItemsControl].DataContext.SelectAnimalGroupCommand}"
                                            CommandParameter="{Binding}">

                                        <Border Classes="timeline-card animal-group-card"
                                                Classes.selected="{Binding IsSelected}">
                                            <StackPanel Spacing="8">
                                                <!-- Group Type ComboBox (Animal Type Selection) -->
                                                <ComboBox ItemsSource="{Binding Path=ValidAnimalTypes}"
                                                          SelectedItem="{Binding Path=GroupType}"
                                                          MinWidth="120"
                                                          HorizontalAlignment="Center"
                                                          Margin="0,4,0,0">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <!-- Group Name Display Section -->
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Path=Name, FallbackValue='Unnamed Group'}"
                                                              FontSize="13"
                                                              FontWeight="Medium"
                                                              Foreground="{StaticResource GcdsTextPrimaryBrush}"
                                                              HorizontalAlignment="Center"
                                                              TextWrapping="Wrap"
                                                              MinHeight="40" />
                                                </StackPanel>

                                                <!-- Delete Button -->
                                                <Button Classes="delete-button"
                                                        Command="{Binding $parent[ItemsControl].DataContext.RemoveAnimalGroupCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding [Label_Delete].Value, Source={StaticResource Loc}}" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Timeline Navigation Hint -->
                    <TextBlock Text="{Binding [Label_TipScrollHorizontally].Value, Source={StaticResource Loc}}"
                               Classes="timeline-hint" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
