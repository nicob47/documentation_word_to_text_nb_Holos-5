<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
			 xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
			 xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.OtherAnimals.OtherAnimalsStep1View">

    <Design.DataContext>
        <componentViews:AnimalComponentViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>

    <StackPanel>

        <StackPanel Classes="step-header">
            <!-- Step Badge -->
            <Border Classes="step-badge">
                <TextBlock Text="Step 1" Classes="step-badge-text" />
            </Border>

            <!-- Step Description -->
            <TextBlock Text="{x:Static properties:Resources.LabelStep1Text}"
                       Classes="step-number-description"
                       VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Command="{Binding OnAddAnimalGroupDtoCommandExecute}" Classes="add-group" Content="{x:Static properties:Resources.ButtonAddGroup}" />
        </StackPanel>

        <!-- Timeline Container -->
        <Border Classes="timeline-container">
            <StackPanel>
                <!-- Timeline Header -->
                <TextBlock Text="Animal Groups" Classes="timeline-header" />

                <!-- Timeline Scrollable Area -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden"
                              MaxHeight="250"
                              MinHeight="150">
                    <ItemsControl ItemsSource="{Binding Path=AnimalGroupDtos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Timeline Card -->
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="4"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch">

                                    <Border Classes="timeline-card animal-group-card">
                                        <StackPanel Spacing="8">
                                            <!-- Group Type ComboBox (Animal Type Selection) -->
                                            <ComboBox ItemsSource="{Binding Path=ValidAnimalTypes}"
                                                      SelectedItem="{Binding Path=GroupType}"
                                                      MinWidth="120"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,4,0,0">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Group Name Display Section -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Path=Name, FallbackValue='Unnamed Group'}"
                                                          FontSize="13"
                                                          FontWeight="Medium"
                                                          Foreground="{StaticResource GcdsTextPrimaryBrush}"
                                                          HorizontalAlignment="Center"
                                                          TextWrapping="Wrap"
                                                          MinHeight="40" />
                                            </StackPanel>

                                            <!-- Delete Button -->
                                            <Button Classes="delete-button">
                                                <!-- Note: Delete functionality requires RemoveSpecificGroupCommand in ViewModel -->
                                                <TextBlock Text="Delete" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Timeline Navigation Hint -->
                <TextBlock Text="Tip: Scroll horizontally to view all groups, click on a group to select it"
                           Classes="timeline-hint" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
