<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:otherAnimals="clr-namespace:H.Avalonia.Views.ComponentViews.OtherAnimals"
			 xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
			 xmlns:poultry="clr-namespace:H.Avalonia.Views.ComponentViews.Poultry"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.Poultry.TurkeyMeatProductionComponentView">

	<Design.DataContext>
        <componentViews:AnimalComponentViewModelDesign/>
	</Design.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Auto"
				 HorizontalScrollBarVisibility="Disabled">
		<StackPanel>
			<poultry:PoultryLifecycleVisualizationView/>
			<otherAnimals:OtherAnimalsComponentsView/>
		</StackPanel>
	</ScrollViewer>

</UserControl>