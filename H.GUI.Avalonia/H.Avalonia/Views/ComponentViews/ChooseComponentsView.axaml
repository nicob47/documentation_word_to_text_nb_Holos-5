<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
             xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
			 xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.ChooseComponentsView">

    <Design.DataContext>
        <componentViews:ChooseComponentsViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Header row -->
            <RowDefinition Height="Auto"/>
            <!-- Content row -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact Header Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource GcdsBgLightBrush}"
                BorderBrush="{StaticResource GcdsBorderLightBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20,12"
                Margin="0,0,0,12">
            <DockPanel>
                <!-- Finish Button (docked right) -->
                <Button DockPanel.Dock="Right"
                        Content="{x:Static properties:Resources.LabelFinishSelectComponent}"
                        Command="{Binding OnFinishedAddingComponentsExecute}"
                        Classes="responsive-button"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0"/>

                <!-- Title and Subtitle (left) -->
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{x:Static properties:Resources.ChooseComponents}"
                              Classes="title-textblock"
                              Margin="0"/>
                    <TextBlock Name="SubtitleText"
                              Text="Select a category to browse available components"
                              FontSize="{StaticResource GcdsFontSizeSmall}"
                              Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Hidden bindings to preserve ViewModel properties -->
        <TextBlock Text="{Binding SelectedComponentTitle}" IsVisible="False"/>
        <TextBlock Text="{Binding SelectedComponentDescription}" IsVisible="False"/>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- STEP 1: Category Selection                              -->
        <!-- ════════════════════════════════════════════════════════ -->
        <ScrollViewer Name="CategoryPanel"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding GroupedComponents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Category Card -->
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0"
                                    Click="OnCategoryClick"
                                    Tag="{Binding}">
                                <Border Width="280"
                                        MinHeight="100"
                                        Background="White"
                                        BorderBrush="{StaticResource GcdsBorderLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="20,16"
                                        Margin="4">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="BorderBrush" Value="{StaticResource GcdsSelectionBorderBrush}"/>
                                            <Setter Property="Background" Value="{StaticResource GcdsSelectionBgBrush}"/>
                                        </Style>
                                    </Border.Styles>

                                    <StackPanel Spacing="8">
                                        <!-- Category Name -->
                                        <TextBlock Text="{Binding CategoryName}"
                                                  FontFamily="{StaticResource GcdsHeadingFont}"
                                                  FontWeight="Bold"
                                                  FontSize="{StaticResource GcdsFontSizeH6}"
                                                  Foreground="{StaticResource GcdsTextPrimaryBrush}"/>

                                        <!-- Component Count -->
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Components.Count}"
                                                      FontSize="{StaticResource GcdsFontSizeSmall}"
                                                      FontWeight="SemiBold"
                                                      Foreground="{StaticResource GcdsLinkDefaultBrush}"/>
                                            <TextBlock Text="components available"
                                                      FontSize="{StaticResource GcdsFontSizeSmall}"
                                                      Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- STEP 2: Component Selection (within chosen category)    -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Name="ComponentPanel"
              Grid.Row="1"
              IsVisible="False">
            <Grid.RowDefinitions>
                <!-- Back button + category title row -->
                <RowDefinition Height="Auto"/>
                <!-- Component cards row -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Back Navigation + Category Title -->
            <StackPanel Grid.Row="0" Margin="4,8,0,16" Spacing="8">
                <Button Name="BackButton"
                        Click="OnBackToCategoriesClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4,4"
                        HorizontalAlignment="Left"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x2190;"
                                  FontSize="{StaticResource GcdsFontSizeBody}"
                                  Foreground="{StaticResource GcdsLinkDefaultBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Back to Categories"
                                  FontSize="{StaticResource GcdsFontSizeBody}"
                                  Foreground="{StaticResource GcdsLinkDefaultBrush}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Name="CategoryTitle"
                          FontFamily="{StaticResource GcdsHeadingFont}"
                          FontWeight="Bold"
                          FontSize="{StaticResource GcdsFontSizeH5}"
                          Foreground="{StaticResource GcdsTextPrimaryBrush}"
                          Margin="0,0,0,4"/>
                <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}"
                       BorderThickness="0,1,0,0"/>
            </StackPanel>

            <!-- Component Cards -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl Name="ComponentItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Component Card -->
                            <Border Width="280"
                                    Height="200"
                                    Background="White"
                                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="4">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="BorderBrush" Value="{StaticResource GcdsSelectionBorderBrush}"/>
                                        <Setter Property="Background" Value="{StaticResource GcdsSelectionBgBrush}"/>
                                    </Style>
                                </Border.Styles>

                                <DockPanel>
                                    <!-- Add Button (docked bottom) -->
                                    <Button DockPanel.Dock="Bottom"
                                            Content="+ Add to Farm"
                                            Click="OnAddComponentClick"
                                            Tag="{Binding}"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"
                                            Padding="16,8"
                                            FontSize="{StaticResource GcdsFontSizeSmall}"
                                            FontWeight="SemiBold"
                                            CornerRadius="4">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="{StaticResource GcdsBgPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="{StaticResource GcdsLinkDefaultBrush}"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>

                                    <!-- Card Content -->
                                    <StackPanel Spacing="8">
                                        <!-- Component Name -->
                                        <TextBlock Text="{Binding Path=ComponentType, Converter={StaticResource EnumDescriptionConverter}}"
                                                  FontFamily="{StaticResource GcdsHeadingFont}"
                                                  FontWeight="Bold"
                                                  FontSize="{StaticResource GcdsFontSizeBody}"
                                                  Foreground="{StaticResource GcdsTextPrimaryBrush}"
                                                  TextWrapping="Wrap"/>

                                        <!-- Component Description -->
                                        <TextBlock Text="{Binding Path=ComponentDescriptionString}"
                                                  FontSize="{StaticResource GcdsFontSizeSmall}"
                                                  Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                  TextWrapping="Wrap"
                                                  MaxLines="3"
                                                  TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
