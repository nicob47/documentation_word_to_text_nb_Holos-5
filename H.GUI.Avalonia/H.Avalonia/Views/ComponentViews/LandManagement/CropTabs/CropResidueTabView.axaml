<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.CropTabs.CropResidueTabView">

    <Border Classes="step-card" Margin="0">
        <StackPanel Grid.IsSharedSizeScope="True" Spacing="0">

            <!-- Section Header -->
            <TextBlock Text="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,8,0,8"/>

            <!-- Section: Biomass Coefficients -->
            <TextBlock Text="{Binding [Label_BiomassCoefficients].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeSmall}" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_BiomassCoefficientProduct].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding BiomassCoefficientProduct}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_BiomassCoefficientStraw].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding BiomassCoefficientStraw}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_BiomassCoefficientRoots].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding BiomassCoefficientRoots}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_BiomassCoefficientExtraroots].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding BiomassCoefficientExtraroot}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Separator Background="{StaticResource GcdsBorderDefaultBrush}" Margin="0,8,0,4"/>

            <!-- Section: Percentage Returned to Soil -->
            <TextBlock Text="{Binding [Label_PercentageReturnedToSoil].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeSmall}" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_ProductYieldReturned].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" FormatString="0.0" Increment="1"
                               Value="{Binding PercentageOfProductYieldReturnedToSoil}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Percentage].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_StrawReturned].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" FormatString="0.0" Increment="1"
                               Value="{Binding PercentageOfStrawReturnedToSoil}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Percentage].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_RootsReturned].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" FormatString="0.0" Increment="1"
                               Value="{Binding PercentageOfRootsReturnedToSoil}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_Percentage].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <Separator Background="{StaticResource GcdsBorderDefaultBrush}" Margin="0,8,0,4"/>

            <!-- Section: Nitrogen Content -->
            <TextBlock Text="{Binding [Label_NitrogenContent].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeSmall}" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NContentInProduct].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding NitrogenContentInProduct}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NContentInStraw].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding NitrogenContentInStraw}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NContentInRoots].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding NitrogenContentInRoots}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NContentInExtraroot].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0000" Increment="0.001"
                               Value="{Binding NitrogenContentInExtraroot}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Separator Background="{StaticResource GcdsBorderDefaultBrush}" Margin="0,8,0,4"/>

            <!-- Section: Carbon & Lignin -->
            <TextBlock Text="{Binding [Label_CarbonAndLignin].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="{StaticResource GcdsFontSizeSmall}" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_CarbonConcentration].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" FormatString="0.00" Increment="0.01"
                               Value="{Binding CarbonConcentration}" HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_LigninContent].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" FormatString="0.0000" Increment="0.001"
                               Value="{Binding LigninContent}" HorizontalAlignment="Stretch"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
