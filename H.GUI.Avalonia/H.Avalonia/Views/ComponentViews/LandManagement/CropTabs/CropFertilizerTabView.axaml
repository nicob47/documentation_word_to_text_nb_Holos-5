<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.CropTabs.CropFertilizerTabView">

    <UserControl.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </UserControl.Resources>

    <Border Classes="step-card" Margin="0">
        <StackPanel Grid.IsSharedSizeScope="True" Spacing="0">

            <!-- Nitrogen fertilizer rate -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NitrogenFertilizerRate].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0" Increment="1"
                               Value="{Binding NitrogenFertilizerRate}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_KgNPerHa].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Phosphorus fertilizer rate -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_PhosphorusFertilizerRate].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0" Increment="1"
                               Value="{Binding PhosphorusFertilizerRate}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_KgPPerHa].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Potassium fertilizer rate -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_PotassiumFertilizerRate].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0" Increment="1"
                               Value="{Binding PotassiumFertilizerRate}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_KgKPerHa].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Sulphur fertilizer rate -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_SulphurFertilizerRate].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" FormatString="0.0" Increment="1"
                               Value="{Binding SulphurFertilizerRate}" HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Text="{Binding [Label_KgSPerHa].Value, Source={StaticResource Loc}}" Classes="unit-label" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Nitrogen fertilizer type -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_NitrogenFertilizerType].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding DataContext.NitrogenFertilizerTypes, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl, AncestorLevel=2}}"
                          SelectedItem="{Binding NitrogenFertilizerType}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" FontSize="{StaticResource GcdsFontSizeSmall}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <!-- Fertilizer blend -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_FertilizerBlend].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding DataContext.FertilizerBlendTypes, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl, AncestorLevel=2}}"
                          SelectedItem="{Binding FertilizerBlend}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" FontSize="{StaticResource GcdsFontSizeSmall}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <!-- Soil reduction factor -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_SoilReductionFactor].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding DataContext.SoilReductionFactorTypes, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl, AncestorLevel=2}}"
                          SelectedItem="{Binding SoilReductionFactor}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" FontSize="{StaticResource GcdsFontSizeSmall}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <!-- Custom reduction factor -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Unit"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_CustomReductionFactor].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" FormatString="0.00" Increment="0.01"
                               Value="{Binding CustomReductionFactor}" HorizontalAlignment="Stretch"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
