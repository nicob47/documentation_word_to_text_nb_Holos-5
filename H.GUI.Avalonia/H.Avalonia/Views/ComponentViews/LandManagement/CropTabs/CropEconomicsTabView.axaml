<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.CropTabs.CropEconomicsTabView">

    <Border Classes="step-card" Margin="0">
        <StackPanel Grid.IsSharedSizeScope="True" Spacing="0">

            <!-- Apply crop economic data -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                    <ColumnDefinition Width="Auto" MinWidth="180" SharedSizeGroup="Input"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [Label_CropEconomicDataApplied].Value, Source={StaticResource Loc}}" Classes="input-label" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding CropEconomicDataApplied}"
                              OnContent="{Binding [Label_Yes].Value, Source={StaticResource Loc}}"
                              OffContent="{Binding [Label_No].Value, Source={StaticResource Loc}}"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
