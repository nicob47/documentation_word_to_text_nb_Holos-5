<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cropTabs="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.CropTabs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="1200"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.CropTabs.CropChecklistEditorView"
             x:Name="ChecklistRoot">

    <StackPanel Spacing="8">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CATEGORY TOGGLE CARD GRID                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">

            <!-- Fertilizer -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Fertilizer].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Fertilizer].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsFertilizerActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

            <!-- Manure -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Manure].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Manure].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsManureActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

            <!-- Grazing -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Grazing].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Grazing].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsGrazingActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

            <!-- Soil -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Soil].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Soil].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsSoilActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

            <!-- Residue -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsResidueActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

            <!-- Economics -->
            <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Tab_Economics].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <ToggleSwitch AutomationProperties.Name="{Binding [Tab_Economics].Value, Source={StaticResource Loc}}" IsChecked="{Binding IsEconomicsActive, ElementName=ChecklistRoot}" Margin="0" Padding="0" OnContent="" OffContent=""/>
                </StackPanel>
            </Border>

        </WrapPanel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CONTENT SECTIONS (only active ones are visible)            -->
        <!-- No outer border — the tab views already have their own     -->
        <!-- visual structure. Just a header + separator between them.   -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- General — always visible -->
        <cropTabs:CropGeneralTabView Margin="0,4,0,0"/>

        <!-- Fertilizer -->
        <cropTabs:CropFertilizerTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsFertilizerActive, ElementName=ChecklistRoot}"/>

        <!-- Manure -->
        <cropTabs:CropManureTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsManureActive, ElementName=ChecklistRoot}"/>

        <!-- Grazing -->
        <cropTabs:CropGrazingTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsGrazingActive, ElementName=ChecklistRoot}"/>

        <!-- Soil -->
        <cropTabs:CropSoilTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsSoilActive, ElementName=ChecklistRoot}"/>

        <!-- Residue -->
        <cropTabs:CropResidueTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsResidueActive, ElementName=ChecklistRoot}"/>

        <!-- Economics -->
        <cropTabs:CropEconomicsTabView Margin="0,4,0,0"
                    IsVisible="{Binding IsEconomicsActive, ElementName=ChecklistRoot}"/>

    </StackPanel>
</UserControl>
