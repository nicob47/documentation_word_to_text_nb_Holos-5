<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cropTabs="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.CropTabs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="1200"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.CropTabs.CropChecklistEditorView"
             x:Name="ChecklistRoot">

    <StackPanel Spacing="16">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CATEGORY TOGGLE CARD GRID                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <TextBlock Text="Select the categories relevant to your operation. Only active categories show input fields below."
                   FontSize="12"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>

        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">

            <!-- General — always active -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="2"
                    BorderBrush="{StaticResource GcdsLinkDefaultBrush}"
                    Background="{StaticResource GcdsSelectionBgBrush}">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✓" Foreground="{StaticResource GcdsLinkDefaultBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding [Tab_General].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Yield, moisture, tillage, harvest" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                    <TextBlock Text="Always active" FontSize="10" Foreground="{StaticResource GcdsLinkDefaultBrush}" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Fertilizer -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsFertilizerActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Fertilizer].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Nitrogen, phosphorus, potassium rates" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Manure -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsManureActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Manure].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Manure application settings" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Grazing -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsGrazingActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Grazing].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Grazing utilization rates" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Soil -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsSoilActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Soil].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Climate, tillage, management factors" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Residue -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsResidueActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Biomass coefficients, nitrogen content" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Economics -->
            <Border Margin="0,0,8,8" Padding="12" CornerRadius="6" Width="260"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    Background="{StaticResource GcdsBgLightBrush}">
                <StackPanel Spacing="4">
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsEconomicsActive, ElementName=ChecklistRoot}" Margin="0" Padding="0"
                                      OnContent="" OffContent=""/>
                        <TextBlock Text="{Binding [Tab_Economics].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Revenue, costs, profit analysis" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

        </WrapPanel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CONTENT SECTIONS (only active ones are visible)            -->
        <!-- No outer border — the tab views already have their own     -->
        <!-- visual structure. Just a header + separator between them.   -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- General — always visible (blue to match card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0">
            <TextBlock Text="{Binding [Tab_General].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{StaticResource GcdsLinkDefaultBrush}"/>
            <Border Height="2" Background="{StaticResource GcdsLinkDefaultBrush}" CornerRadius="1"/>
            <cropTabs:CropGeneralTabView/>
        </StackPanel>

        <!-- Fertilizer (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsFertilizerActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Fertilizer].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropFertilizerTabView/>
        </StackPanel>

        <!-- Manure (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsManureActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Manure].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropManureTabView/>
        </StackPanel>

        <!-- Grazing (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsGrazingActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Grazing].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropGrazingTabView/>
        </StackPanel>

        <!-- Soil (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsSoilActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Soil].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropSoilTabView/>
        </StackPanel>

        <!-- Residue (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsResidueActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropResidueTabView/>
        </StackPanel>

        <!-- Economics (green to match active card) -->
        <StackPanel Spacing="8" Margin="0,4,0,0"
                    IsVisible="{Binding IsEconomicsActive, ElementName=ChecklistRoot}">
            <TextBlock Text="{Binding [Tab_Economics].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                       Foreground="#4CAF50"/>
            <Border Height="2" Background="#4CAF50" CornerRadius="1"/>
            <cropTabs:CropEconomicsTabView/>
        </StackPanel>

    </StackPanel>
</UserControl>
