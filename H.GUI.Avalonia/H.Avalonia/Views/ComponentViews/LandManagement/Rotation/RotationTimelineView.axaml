<UserControl x:Name="RotationTimelineRootControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
             xmlns:converters="clr-namespace:H.Avalonia.Converters"
             xmlns:dataTemplates="clr-namespace:H.Avalonia.DataTemplates"
             mc:Ignorable="d"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationTimelineView">

    <Design.DataContext>
        <rotation:RotationComponentViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
        <!-- Add converters for selection styling -->
        <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
        <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
        <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
        <converters:BoolToScaleTransformConverter x:Key="BoolToScaleTransformConverter"/>
        <converters:CropTypeToColorConverter x:Key="CropTypeToColorConverter"/>
        <converters:IndexToOrdinalConverter x:Key="IndexToOrdinalConverter"/>
        <!-- Data template selector: renders category headers vs. crop items differently -->
        <dataTemplates:CropGroupedItemDataTemplate x:Key="CropGroupedItemDataTemplate"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- White popup background for the crop ComboBox so category colours read clearly -->
        <Style Selector="ComboBox.crop-selector /template/ Border#Background">
            <Setter Property="Background" Value="White"/>
        </Style>
        <!-- Override ComboBoxItem: white background, stretch content to full width -->
        <Style Selector="ComboBox.crop-selector ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ComboBox.crop-selector ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EBF2FA"/>
        </Style>
    </UserControl.Styles>

    <!-- Step 2: Build Rotation Timeline -->
    <Border x:Name="StepContainerBorder" Classes="step-container">
        <StackPanel>
            <!-- Step Header -->
            <StackPanel x:Name="StepHeaderPanel" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <Border x:Name="StepBadgeBorder" Classes="step-badge" VerticalAlignment="Top">
                    <TextBlock x:Name="StepNumberTextBlock" Text="{Binding [Label_StepTwo].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="StepTitleTextBlock"
                               Text="{Binding [Label_BuildYourRotationSequence].Value, Source={StaticResource Loc}}"
                               Classes="step-number-description"/>
                    <TextBlock x:Name="StepDescriptionTextBlock"
                               Text="{Binding [Label_AddCropsToRotationDesc].Value, Source={StaticResource Loc}}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Step header separator -->
            <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

            <!-- Timeline Controls -->
            <StackPanel x:Name="TimelineControlsPanel" Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="AddCropButton"
                        Content="{Binding [Button_AddCrop].Value, Source={StaticResource Loc}}"
                        Command="{Binding AddCropToRotationCommand}"
                        Margin="0,0,8,0"/>
            </StackPanel>

            <!-- Crop Table - Only visible when crops exist -->
            <StackPanel IsVisible="{Binding CropDtos.Count}">

                <!-- Table Header -->
                <Border Background="#F3F4F6" Padding="8,6"
                        BorderBrush="{StaticResource GcdsBorderLightBrush}"
                        BorderThickness="1,1,1,1" CornerRadius="6,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sequence" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Main Crop" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="Cover Crop" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="Actions" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Table Rows -->
                <Border BorderBrush="{StaticResource GcdsBorderLightBrush}"
                        BorderThickness="1,0,1,1" CornerRadius="0,0,6,6"
                        ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding CropDtos}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6"
                                        BorderBrush="{StaticResource GcdsBorderLightBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>

                                            <!-- Sequence column color accent: negative margins negate the parent's Padding="8,6" on
                                                 left/top/bottom so the color fills flush to the row edges, stopping at Column 0. -->
                                            <Border Grid.Column="0"
                                                    Margin="-8,-6,0,-6"
                                                    Background="{Binding CropType, Converter={StaticResource CropTypeToColorConverter}}"/>

                                            <!-- Sequence -->
                                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding SequenceLabel}"/>

                                            <!-- Main Crop -->
                                            <ComboBox Grid.Column="1" Classes="crop-selector"
                                                      ItemsSource="{Binding GroupedCropItems}"
                                                      SelectedItem="{Binding SelectedCropTypeItem}"
                                                      ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                      HorizontalAlignment="Stretch"
                                                      Margin="8,0,0,0"
                                                      MaxDropDownHeight="320"/>

                                            <!-- Cover Crop -->
                                            <DockPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <Button DockPanel.Dock="Left" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,6,0"
                                                        Command="{Binding $parent[UserControl].((rotation:RotationComponentViewModel)DataContext).ToggleCoverCropCommand}"
                                                        CommandParameter="{Binding}">
                                                    <CheckBox IsChecked="{Binding HasCoverCrop, Mode=OneWay}"
                                                              IsHitTestVisible="False" MinWidth="0" Padding="0"/>
                                                </Button>
                                                <TextBlock DockPanel.Dock="Left" Text="None" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                           IsVisible="{Binding !HasCoverCrop}" VerticalAlignment="Center" FontStyle="Italic"/>
                                                <ComboBox Classes="crop-selector"
                                                          IsVisible="{Binding HasCoverCrop}"
                                                          ItemsSource="{Binding CoverCropDto.GroupedCropItems}"
                                                          SelectedItem="{Binding CoverCropDto.SelectedCropTypeItem}"
                                                          ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                          HorizontalAlignment="Stretch"
                                                          MaxDropDownHeight="320"/>
                                            </DockPanel>

                                            <!-- Actions: Move Up, Move Down, Delete -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1"
                                                        CornerRadius="4" Padding="4,2" MinWidth="0" MinHeight="0" Width="24" Height="24"
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((rotation:RotationComponentViewModel)DataContext).MoveCropUpCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="▲" FontSize="11" Foreground="#6B7280"/>
                                                </Button>
                                                <Button Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1"
                                                        CornerRadius="4" Padding="4,2" MinWidth="0" MinHeight="0" Width="24" Height="24"
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((rotation:RotationComponentViewModel)DataContext).MoveCropDownCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="▼" FontSize="11" Foreground="#6B7280"/>
                                                </Button>
                                                <Button Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1"
                                                        CornerRadius="4" Padding="4,2" MinWidth="0" MinHeight="0" Width="24" Height="24"
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((rotation:RotationComponentViewModel)DataContext).RemoveSpecificCropCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="🗑" FontSize="11"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>



            <!-- Empty State Message -->
            <Border x:Name="EmptyStateMessageBorder"
                    IsVisible="{Binding !CropDtos.Count}"
                    Background="{StaticResource GcdsWarningBgBrush}"
                    BorderBrush="{StaticResource GcdsWarningBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0,12,0,0">
                <TextBlock x:Name="EmptyStateMessageTextBlock"
                           Text="{Binding [Label_AddAtLeastOneCrop].Value, Source={StaticResource Loc}}"
                           Foreground="{StaticResource GcdsTextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
