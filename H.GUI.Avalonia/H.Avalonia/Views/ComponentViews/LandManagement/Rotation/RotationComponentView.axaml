<UserControl xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
xmlns:rotationViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Rotation"
xmlns:cropTabs="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.CropTabs"
mc:Ignorable="d"
x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationComponentView">

<Design.DataContext>
<rotation:RotationComponentViewModelDesign/>
</Design.DataContext>


	<Grid>
		<Grid.RowDefinitions>
			<!-- Title -->
			<RowDefinition Height="Auto"/>
			<!-- Advanced Options Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<!-- Title -->
			<TextBox Classes="view-title" Text="{Binding Path=SelectedRotationComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Advanced Options Toggle Section -->
		<shared:AdvancedOptionsToggleView Grid.Row="1"
										  Margin="{StaticResource DefaultUserControlMargin}"
										  Title="{Binding [Label_ShowAdvancedOptions].Value, Source={StaticResource Loc}}"
										  Description="{Binding [Label_ShowAdvancedOptionsRotationDesc].Value, Source={StaticResource Loc}}"
										  IsChecked="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"/>

		<!-- Main Content Area with Timeline-Based Approach -->
		<ScrollViewer Grid.Row="2"
					  Name="MainScrollViewer"
					  VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="0,0,0,40">

				<!-- Step 1: Rotation Overview -->
				<rotationViews:RotationOverviewView Margin="{StaticResource DefaultUserControlMargin}"
				                                    DataContext="{Binding}"/>

				<!-- Step Divider -->
				<GridSplitter Height="2"
							  Background="{StaticResource GcdsBorderDefaultBrush}"
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"/>

				<!-- Step 2: Build Rotation Timeline -->
				<rotationViews:RotationTimelineView Margin="{StaticResource DefaultUserControlMargin}"
				                                    DataContext="{Binding}"/>

				<!-- Step Divider -->
				<GridSplitter Height="2"
							  Background="{StaticResource GcdsBorderDefaultBrush}"
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"/>

				<!-- Step 3: Preview Field Assignments -->
				<rotationViews:RotationPreviewView DataContext="{Binding}"
												   IsVisible="{Binding ShouldShowPreview}"/>

				<!-- Step Divider -->
				<GridSplitter Height="2"
							  Background="{StaticResource GcdsBorderDefaultBrush}"
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"
							  IsVisible="{Binding ShouldShowPreview}"/>

				<!-- Step 4: Edit Crop Details - Only show when a cell is selected -->
				<Border Classes="step-container"
						Margin="{StaticResource DefaultUserControlMargin}"
						IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}">
					<StackPanel>
						<!-- Step Header -->
						<StackPanel Margin="0,0,0,20">
							<Border Classes="step-badge" HorizontalAlignment="Left">
								<TextBlock Text="{Binding [Label_StepFour].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
							</Border>
							<TextBlock Text="{Binding [Label_EditCropDetails].Value, Source={StaticResource Loc}}"
									   Classes="step-number-description"
									   Margin="0,8,0,0"/>
							<TextBlock Text="{Binding [Label_EditCropDetailsDesc].Value, Source={StaticResource Loc}}"
									   Foreground="{StaticResource GcdsTextSecondaryBrush}"
									   FontSize="12"
									   Margin="0,4,0,0"/>
						</StackPanel>

						<!-- Currently Editing Indicator -->
						<Border IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}"
								Background="{StaticResource GcdsSelectionBgBrush}"
								BorderBrush="{StaticResource GcdsLinkDefaultBrush}"
								BorderThickness="1"
								CornerRadius="6"
								Padding="12"
								Margin="0,0,0,16">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<StackPanel VerticalAlignment="Center">
									<TextBlock>
										<Run Text="{Binding [Label_CurrentlyEditing].Value, Source={StaticResource Loc}}"/>
										<Run Text="{Binding SelectedCropDto.CropType, Mode=OneWay}"
											 FontWeight="Bold"/>
										<Run Text="(Year"/>
										<Run Text="{Binding SelectedCropDto.Year, Mode=OneWay}"
											 FontWeight="Bold"/>
										<Run Text=")"/>
									</TextBlock>
									<TextBlock FontSize="12"
											   Foreground="{StaticResource GcdsTextSecondaryBrush}"
											   Margin="0,2,0,0">
										<Run Text="{Binding [Label_Field].Value, Source={StaticResource Loc}}"/>
										<Run Text="{Binding SelectedFieldName, Mode=OneWay}"
											 FontWeight="SemiBold"/>
									</TextBlock>
								</StackPanel>
							</StackPanel>
						</Border>

						<!-- Copy to Similar Crops Toggle -->
						<Border IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}"
								Background="{StaticResource GcdsBgLightBrush}"
								BorderBrush="{StaticResource GcdsBorderLightBrush}"
								BorderThickness="1"
								CornerRadius="6"
								Padding="12"
								Margin="0,0,0,16">
							<StackPanel Spacing="8">
								<TextBlock Text="{Binding [Label_CopyToSimilarCrops].Value, Source={StaticResource Loc}}"
										   FontWeight="SemiBold"
										   FontSize="13"
										   Foreground="{StaticResource GcdsTextPrimaryBrush}"
										   VerticalAlignment="Center"/>
								<TextBlock Text="{Binding [Label_CopyToSimilarCropsDesc].Value, Source={StaticResource Loc}}"
										   TextWrapping="Wrap"
										   FontSize="12"
										   Foreground="{StaticResource GcdsTextSecondaryBrush}"
										   Margin="0,0,0,4"/>
								<ToggleSwitch IsChecked="{Binding SelectedCropDto.CopyToSimilarCrops}"
											  OnContent="{Binding [Label_CopyEnabled].Value, Source={StaticResource Loc}}"
											  OffContent="{Binding [Label_CopyDisabled].Value, Source={StaticResource Loc}}"/>
							</StackPanel>
						</Border>

						<!-- Editing context toggle: Main Crop ↔ Cover Crop -->
						<Border IsVisible="{Binding SelectedCropDto.HasCoverCrop, FallbackValue=False}"
								Margin="0,0,0,12">
							<ToggleSwitch IsChecked="{Binding IsEditingCoverCrop}"
										  OnContent="{Binding SelectedCropDto.CoverCropDto.CropType, StringFormat='Editing Cover Crop ({0})'}"
										  OffContent="{Binding SelectedCropDto.CropType, StringFormat='Editing Main Crop ({0})'}"/>
						</Border>

						<!-- Crop Details TabControl - shown when NOT editing cover crop -->
						<TabControl IsVisible="{Binding IsEditingCoverCrop, Converter={x:Static BoolConverters.Not}}"
									DataContext="{Binding SelectedCropDto}"
									Background="White"
									MinHeight="450">
							<TabItem Header="{Binding [Tab_General].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropGeneralTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Fertilizer].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropFertilizerTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Manure].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropManureTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Grazing].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropGrazingTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Soil].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropSoilTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Residue].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropResidueTabView/></ScrollViewer>
							</TabItem>
							<TabItem Header="{Binding [Tab_Economics].Value, Source={StaticResource Loc}}">
								<ScrollViewer><cropTabs:CropEconomicsTabView/></ScrollViewer>
							</TabItem>
						</TabControl>

						<!-- Cover Crop Editor - shown when editing cover crop -->
						<Border IsVisible="{Binding IsEditingCoverCrop}"
								MinHeight="450">
							<cropTabs:CoverCropEditorView DataContext="{Binding SelectedCropDto.CoverCropDto}"/>
						</Border>

						<!-- Empty State Message when no crop is selected -->
						<Border IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNull}}"
								Background="{StaticResource GcdsBgLightBrush}"
								BorderBrush="{StaticResource GcdsBorderLightBrush}"
								BorderThickness="1"
								CornerRadius="6"
								Padding="16">
							<TextBlock Text="{Binding [Label_ClickCellToEditDetails].Value, Source={StaticResource Loc}}"
									   Foreground="{StaticResource GcdsTextSecondaryBrush}"
									   VerticalAlignment="Center"/>
						</Border>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
