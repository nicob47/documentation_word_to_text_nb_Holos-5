<UserControl xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
xmlns:rotationViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Rotation"
xmlns:cropTabs="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.CropTabs"
mc:Ignorable="d"
x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationComponentView">

<Design.DataContext>
<rotation:RotationComponentViewModelDesign/>
</Design.DataContext>


	<Grid>
		<Grid.RowDefinitions>
			<!-- Title + Advanced Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<TextBox Classes="view-title" Text="{Binding Path=SelectedRotationComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Main Content Area with Timeline-Based Approach -->
		<ScrollViewer Grid.Row="1"
					  Name="MainScrollViewer"
					  VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="0,0,0,40">

				<!-- Step 1: Rotation Overview -->
				<rotationViews:RotationOverviewView Margin="{StaticResource DefaultUserControlMargin}"
				                                    DataContext="{Binding}"/>

				<!-- Step 2: Build Rotation Timeline -->
				<rotationViews:RotationTimelineView Margin="{StaticResource DefaultUserControlMargin}"
				                                    DataContext="{Binding}"/>

				<!-- Step 3: Preview Field Assignments -->
				<rotationViews:RotationPreviewView DataContext="{Binding}"
												   IsVisible="{Binding ShouldShowPreview}"/>

				<!-- Step 4: Edit Crop Details - Only show when a cell is selected -->
				<Border Classes="step-container"
						Margin="{StaticResource DefaultUserControlMargin}"
						IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}">
					<StackPanel>
						<!-- Step Header with inline editing info -->
						<Grid Margin="0,0,0,12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<!-- Left: Step badge + title -->
							<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
								<Border Classes="step-badge" VerticalAlignment="Top">
									<TextBlock Text="{Binding [Label_StepFour].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
								</Border>
								<StackPanel VerticalAlignment="Center">
									<TextBlock Text="{Binding [Label_EditCropDetails].Value, Source={StaticResource Loc}}"
											   Classes="step-number-description"/>
									<TextBlock Text="{Binding [Label_EditCropDetailsDesc].Value, Source={StaticResource Loc}}"
											   Foreground="{StaticResource GcdsTextSecondaryBrush}"
											   FontSize="12"
											   Margin="0,2,0,0"/>
								</StackPanel>
							</StackPanel>

							<!-- Right: Currently editing info + copy toggle -->
							<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
										HorizontalAlignment="Right" VerticalAlignment="Center"
										IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}">
								<!-- Crop info -->
								<StackPanel VerticalAlignment="Center">
									<TextBlock FontSize="13" FontWeight="SemiBold">
										<Run Text="{Binding SelectedCropDto.CropType, Mode=OneWay}"/>
										<Run Text="("/>
										<Run Text="{Binding SelectedCropDto.Year, Mode=OneWay}"/>
										<Run Text=")"/>
									</TextBlock>
									<TextBlock FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}">
										<Run Text="{Binding SelectedFieldName, Mode=OneWay}"/>
									</TextBlock>
								</StackPanel>

								<!-- Separator -->
								<Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1,0,0,0" Height="30"/>

								<!-- Cover crop toggle (only when cover crop exists) -->
								<ToggleSwitch IsVisible="{Binding SelectedCropDto.HasCoverCrop, FallbackValue=False}"
											  IsChecked="{Binding IsEditingCoverCrop}"
											  OnContent="{Binding SelectedCropDto.CoverCropDto.CropType, StringFormat='Cover Crop ({0})'}"
											  OffContent="{Binding SelectedCropDto.CropType, StringFormat='Main Crop ({0})'}"
											  VerticalAlignment="Center" Padding="0" Margin="0"/>

								<!-- Separator -->
								<Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1,0,0,0" Height="30"
										IsVisible="{Binding SelectedCropDto.HasCoverCrop, FallbackValue=False}"/>

								<!-- Copy toggle -->
								<ToggleSwitch IsChecked="{Binding SelectedCropDto.CopyToSimilarCrops}"
											  OnContent="{Binding [Label_CopyEnabled].Value, Source={StaticResource Loc}}"
											  OffContent="{Binding [Label_CopyDisabled].Value, Source={StaticResource Loc}}"
											  VerticalAlignment="Center" Padding="0" Margin="0"/>
							</StackPanel>
						</Grid>

						<!-- Step header separator -->
						<Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

						<!-- Checklist Editor - shown when NOT editing cover crop -->
						<cropTabs:CropChecklistEditorView
							IsVisible="{Binding DataContext.IsEditingCoverCrop, Converter={x:Static BoolConverters.Not}, RelativeSource={RelativeSource AncestorType=UserControl}}"
							DataContext="{Binding SelectedCropDto}"
							IsFertilizerActive="{Binding DataContext.IsFertilizerActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsManureActive="{Binding DataContext.IsManureActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsGrazingActive="{Binding DataContext.IsGrazingActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsSoilActive="{Binding DataContext.IsSoilActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsResidueActive="{Binding DataContext.IsResidueActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsEconomicsActive="{Binding DataContext.IsEconomicsActive, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

						<!-- Checklist Editor - shown when editing cover crop -->
						<cropTabs:CropChecklistEditorView
							IsVisible="{Binding DataContext.IsEditingCoverCrop, RelativeSource={RelativeSource AncestorType=UserControl}}"
							DataContext="{Binding SelectedCropDto.CoverCropDto}"
							IsFertilizerActive="{Binding DataContext.IsFertilizerActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsManureActive="{Binding DataContext.IsManureActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsGrazingActive="{Binding DataContext.IsGrazingActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsSoilActive="{Binding DataContext.IsSoilActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsResidueActive="{Binding DataContext.IsResidueActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
							IsEconomicsActive="{Binding DataContext.IsEconomicsActive, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

						<!-- Empty State Message when no crop is selected -->
						<Border IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNull}}"
								Background="{StaticResource GcdsBgLightBrush}"
								BorderBrush="{StaticResource GcdsBorderLightBrush}"
								BorderThickness="1"
								CornerRadius="6"
								Padding="16">
							<TextBlock Text="{Binding [Label_ClickCellToEditDetails].Value, Source={StaticResource Loc}}"
									   Foreground="{StaticResource GcdsTextSecondaryBrush}"
									   VerticalAlignment="Center"/>
						</Border>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
