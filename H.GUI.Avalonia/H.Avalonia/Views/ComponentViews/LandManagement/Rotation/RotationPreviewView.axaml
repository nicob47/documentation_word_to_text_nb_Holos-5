<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
         xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
         xmlns:converters="clr-namespace:H.Avalonia.Converters"
         mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
         x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationPreviewView">

<Design.DataContext>
    <rotation:RotationComponentViewModelDesign/>
</Design.DataContext>

<UserControl.Resources>
    <!-- Add converters for selection styling -->
    <converters:BoolToSelectionBorderThicknessConverter x:Key="BoolToSelectionBorderThicknessConverter"/>
    <converters:BoolToSelectionBorderBrushConverter x:Key="BoolToSelectionBorderBrushConverter"/>
</UserControl.Resources>

    <!-- Step 3: Preview Field Assignment -->
    <Border Classes="step-container"
            Margin="{StaticResource DefaultUserControlMargin}">
        <StackPanel>
            <!-- Step Header -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <Border Classes="step-badge" VerticalAlignment="Top">
                    <TextBlock Text="{Binding [Label_StepThree].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Label_PreviewFieldAssignments].Value, Source={StaticResource Loc}}"
                               Classes="step-number-description"/>
                    <TextBlock Text="{Binding [Label_ReviewHowCropsDistributed].Value, Source={StaticResource Loc}}"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Step header separator -->
            <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

            <!-- Preview Grid - Only visible when both NumberOfFields > 0 AND crops exist -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          IsVisible="{Binding ShouldShowPreview}">
                    <Grid Margin="0,0,0,16">
                        <!-- Dynamic ItemsControl to display field rows -->
                        <ItemsControl ItemsSource="{Binding FieldAssignmentRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Each row showing one field's crop assignments across years -->
                                    <Border BorderBrush="{StaticResource GcdsBorderLightBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <!-- Field name column -->
                                                <ColumnDefinition Width="150"/>
                                                <!-- Remaining space for year columns -->
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Field Name -->
                                            <Border Grid.Column="0"
                                                    Background="{StaticResource GcdsBgLightBrush}"
                                                    Padding="12,8"
                                                    Margin="0,0,8,0"
                                                    CornerRadius="4">
                                                <TextBlock Text="{Binding FieldName}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Year/Crop Assignments -->
                                            <ItemsControl Grid.Column="1"
                                                          ItemsSource="{Binding YearAssignments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Each year/crop cell with fixed width and selection highlighting - Now clickable -->
                                                        <Button Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="0"
                                                                Cursor="Hand"
                                                                Command="{Binding $parent[UserControl].((rotation:RotationComponentViewModel)DataContext).SetSelectedCropFromCellCommand}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Styles>
                                                                <Style Selector="Button:pointerover">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                </Style>
                                                                <Style Selector="Button:pressed">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                </Style>
                                                            </Button.Styles>
                                                            <Border Background="{Binding CropBackground}"
                                                                    Padding="8,8"
                                                                    Width="120"
                                                                    Height="80"
                                                                    CornerRadius="4"
                                                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToSelectionBorderBrushConverter}}"
                                                                    BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToSelectionBorderThicknessConverter}}">
                                                                <Border.Styles>
                                                                    <Style Selector="Border:pointerover">
                                                                        <Setter Property="Opacity" Value="0.85"/>
                                                                    </Style>
                                                                </Border.Styles>
                                                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                                                    <!-- Year label -->
                                                                    <TextBlock Text="{Binding Year}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                                               TextAlignment="Center"/>
                                                                    <!-- Crop name with icon - with text trimming -->
                                                                    <TextBlock Text="{Binding CropDisplay}"
                                                                               TextAlignment="Center"
                                                                               TextWrapping="Wrap"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="2"
                                                                               FontWeight="Medium"
                                                                               Foreground="{DynamicResource TextControlForeground}"
                                                                               ToolTip.Tip="{Binding CropDisplay}"/>
                                                                    <!-- Cover crop indicator -->
                                                                    <TextBlock Text="{Binding CoverCropDisplay}"
                                                                               IsVisible="{Binding HasCoverCrop}"
                                                                               TextAlignment="Center"
                                                                               FontSize="10"
                                                                               FontStyle="Italic"
                                                                               Foreground="#2E7D32"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1"
                                                                               ToolTip.Tip="{Binding CoverCropDisplay}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
            </ScrollViewer>

            <!-- Hint text -->
            <TextBlock Text="Click a crop card above to edit its properties."
                       FontSize="12" FontStyle="Italic"
                       Foreground="{StaticResource GcdsTextSecondaryBrush}"
                       Margin="0,4,0,0"
                       IsVisible="{Binding ShouldShowPreview}"/>

            <!-- Empty State Message when preview should not be shown -->
            <Border IsVisible="{Binding !ShouldShowPreview}"
                    Background="{StaticResource GcdsWarningBgBrush}"
                    BorderBrush="{StaticResource GcdsWarningBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding [Label_PreviewRequirements].Value, Source={StaticResource Loc}}" FontWeight="SemiBold" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding [Label_PreviewRequireFields].Value, Source={StaticResource Loc}}" Foreground="{StaticResource GcdsTextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding [Label_PreviewRequireCrops].Value, Source={StaticResource Loc}}" Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
