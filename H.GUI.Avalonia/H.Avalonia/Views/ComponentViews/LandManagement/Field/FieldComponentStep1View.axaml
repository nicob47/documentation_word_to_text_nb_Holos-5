<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:fieldViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             mc:Ignorable="d"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentStep1View">

	<Design.DataContext>
		<field:FieldComponentViewModelDesign/>
	</Design.DataContext>

	<StackPanel>
        <!-- Step Header -->
        <StackPanel Margin="0,0,0,20">
            <Border Classes="step-badge" HorizontalAlignment="Left">
                <TextBlock Text="Step 1" Classes="step-badge-text"/>
            </Border>
            <TextBlock Text="Enter basic information for this field"
                       Classes="step-number-description"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Field Information Card -->
        <Border Classes="step-card">
            <StackPanel>
                <!-- Card Header -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Field Details"
                              FontSize="{StaticResource GcdsFontSizeH6}"
                              FontWeight="Bold"
                              FontFamily="{StaticResource GcdsHeadingFont}"
                              Foreground="{StaticResource GcdsTextPrimaryBrush}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="Configure the area and time period for this field"
                              FontSize="{StaticResource GcdsFontSizeSmall}"
                              Foreground="{StaticResource GcdsTextSecondaryBrush}"
                              FontStyle="Italic"/>
                </StackPanel>

                <!-- Card Content -->
                <Grid VerticalAlignment="Top" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="160"/>
                        <ColumnDefinition MinWidth="120"/>
                        <ColumnDefinition MinWidth="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Field Size Row -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Content="Field size:"
                           Classes="input-label"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                  Minimum="0"
                                  Value="{Binding Path=SelectedFieldSystemComponentDto.FieldArea}"/>
                    <Label Grid.Row="0" Grid.Column="2"
                           Classes="unit-label"
                           Content="{Binding Path=StorageService.Storage.ApplicationData.DisplayUnitStrings.HectaresString}"/>

                    <!-- Start Year Row -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Content="Start year:"
                           Classes="input-label"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1"
                                  Minimum="0"
                                  FormatString="0"
                                  ParsingNumberStyle="Integer"
                                  Value="{Binding Path=SelectedFieldSystemComponentDto.StartYear}"/>
                    <Label Grid.Row="1" Grid.Column="2"
                           Classes="unit-label"
                           Content=""/>

                    <!-- End Year Row -->
                    <Label Grid.Row="2" Grid.Column="0"
                           Content="End year:"
                           Classes="input-label"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="1"
                                  Minimum="0"
                                  FormatString="0"
                                  ParsingNumberStyle="Integer"
                                  Value="{Binding Path=SelectedFieldSystemComponentDto.EndYear}"/>
                    <Label Grid.Row="2" Grid.Column="2"
                           Classes="unit-label"
                           Content=""/>
                </Grid>
            </StackPanel>
        </Border>
	</StackPanel>
</UserControl>
