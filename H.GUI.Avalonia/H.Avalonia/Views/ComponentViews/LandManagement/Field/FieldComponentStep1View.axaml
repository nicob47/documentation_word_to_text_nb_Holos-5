<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:fieldViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             mc:Ignorable="d"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentStep1View">

	<Design.DataContext>
		<field:FieldComponentViewModelDesign/>
	</Design.DataContext>

	<StackPanel>
        <!-- Step Header -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <Border Classes="step-badge" VerticalAlignment="Top">
                <TextBlock Text="{Binding [Label_StepOne].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding [Label_EnterBasicInfoForField].Value, Source={StaticResource Loc}}"
                           Classes="step-number-description"/>
            </StackPanel>
        </StackPanel>

        <!-- Step header separator -->
        <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

        <!-- Field details — inline inputs -->
        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="160"/>
                <ColumnDefinition MinWidth="120"/>
                <ColumnDefinition MinWidth="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Field Size Row -->
            <Label Grid.Row="0" Grid.Column="0"
                   Content="{Binding [Label_FieldSize].Value, Source={StaticResource Loc}}"
                   Classes="input-label"/>
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                          Minimum="0"
                          Value="{Binding Path=SelectedFieldSystemComponentDto.FieldArea}"/>
            <Label Grid.Row="0" Grid.Column="2"
                   Classes="unit-label"
                   Content="{Binding Path=StorageService.Storage.ApplicationData.DisplayUnitStrings.HectaresString}"/>

            <!-- Start Year Row -->
            <Label Grid.Row="1" Grid.Column="0"
                   Content="{Binding [Label_StartYear].Value, Source={StaticResource Loc}}"
                   Classes="input-label"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                          Minimum="0"
                          FormatString="0"
                          ParsingNumberStyle="Integer"
                          Value="{Binding Path=SelectedFieldSystemComponentDto.StartYear}"/>

            <!-- End Year Row -->
            <Label Grid.Row="2" Grid.Column="0"
                   Content="{Binding [Label_EndYear].Value, Source={StaticResource Loc}}"
                   Classes="input-label"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1"
                          Minimum="0"
                          FormatString="0"
                          ParsingNumberStyle="Integer"
                          Value="{Binding Path=SelectedFieldSystemComponentDto.EndYear}"/>
        </Grid>
	</StackPanel>
</UserControl>
