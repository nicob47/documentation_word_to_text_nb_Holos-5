<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:converters="clr-namespace:H.Avalonia.Converters"
             xmlns:dataTemplates="clr-namespace:H.Avalonia.DataTemplates"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentStep2View">

    <UserControl.Resources>
        <converters:CropTypeToColorConverter x:Key="CropTypeToColorConverter"/>
        <dataTemplates:CropGroupedItemDataTemplate x:Key="CropGroupedItemDataTemplate"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ComboBox.crop-selector /template/ Border#Background">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="ComboBox.crop-selector ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ComboBox.crop-selector ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EBF2FA"/>
        </Style>
    </UserControl.Styles>

    <Design.DataContext>
        <field:FieldComponentViewModelDesign />
    </Design.DataContext>

    <StackPanel>

        <!-- Step Header with Vertical Layout -->
        <StackPanel Margin="0,0,0,20">
            <!-- Step Badge -->
            <Border Classes="step-badge" HorizontalAlignment="Left">
                <TextBlock Text="{Binding [Label_StepTwo].Value, Source={StaticResource Loc}}" Classes="step-badge-text" />
            </Border>

            <!-- Step Description below badge -->
            <TextBlock Text="{Binding [Label_EnterFieldHistory].Value, Source={StaticResource Loc}}"
                       Classes="step-number-description"
                       Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Command="{Binding AddCropCommand}" Classes="add-group" Content="{Binding [Button_AddCropToField].Value, Source={StaticResource Loc}}" />
        </StackPanel>

        <!-- Timeline Container -->
        <Border Classes="timeline-container">
            <StackPanel>
                <!-- Timeline Header -->
                <TextBlock Text="{Binding [Label_FieldHistoryTimeline].Value, Source={StaticResource Loc}}" Classes="timeline-header" />

                <!-- Timeline Scrollable Area -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden"
                              MaxHeight="250"
                              MinHeight="150">
                    <ItemsControl ItemsSource="{Binding Path=SelectedFieldSystemComponentDto.CropDtos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Timeline Card -->
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="4"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).SetSelectedCropCommand}"
                                        CommandParameter="{Binding}">

                                    <Border Classes="timeline-card"
                                            Background="{Binding CropType, Converter={StaticResource CropTypeToColorConverter}}">
                                        <StackPanel Spacing="8" Margin="8">
                                            <!-- Top row with Year Badge and Delete Button in same DockPanel for perfect alignment -->
                                            <DockPanel LastChildFill="False">
                                                <!-- Year Badge -->
                                                <Border Classes="year-badge"
                                                        DockPanel.Dock="Left"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Path=Year}"
                                                               Classes="year-badge-text"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                <!-- Delete Button -->
                                                <Button Classes="delete-button"
                                                        DockPanel.Dock="Right"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).RemoveSpecificCropCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Name="DeleteTextBlock"
                                                               Classes="delete-text"
                                                               Text="{Binding [Label_Delete].Value, Source={StaticResource Loc}}"/>
                                                </Button>
                                            </DockPanel>

                                            <!-- Crop Type Section -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding [Label_SelectCrop].Value, Source={StaticResource Loc}}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Left" />

                                                <ComboBox Classes="crop-selector"
                                                          ItemsSource="{Binding GroupedCropItems}"
                                                          SelectedItem="{Binding SelectedCropTypeItem}"
                                                          ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                          Width="240"
                                                          MaxDropDownHeight="320"/>
                                            </StackPanel>

                                            <!-- Cover Crop Toggle -->
                                            <Button Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).ToggleCoverCropCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <CheckBox IsChecked="{Binding HasCoverCrop, Mode=OneWay}"
                                                              IsHitTestVisible="False"/>
                                                    <TextBlock Text="Cover Crop"
                                                               FontSize="11"
                                                               Foreground="#2E7D32"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Cover Crop Type Selector (visible when cover crop enabled) -->
                                            <StackPanel Spacing="4"
                                                        IsVisible="{Binding HasCoverCrop}">
                                                <TextBlock Text="Cover Crop Type"
                                                           FontSize="12"
                                                           Foreground="#2E7D32"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Left" />
                                                <ComboBox Classes="crop-selector"
                                                          ItemsSource="{Binding CoverCropDto.GroupedCropItems}"
                                                          SelectedItem="{Binding CoverCropDto.SelectedCropTypeItem}"
                                                          ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                          Width="240"
                                                          MaxDropDownHeight="320"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Timeline Navigation Hint -->
                <TextBlock Text="{Binding [Label_TimelineScrollHint].Value, Source={StaticResource Loc}}"
                           Classes="timeline-hint" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
