<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:converters="clr-namespace:H.Avalonia.Converters"
             xmlns:dataTemplates="clr-namespace:H.Avalonia.DataTemplates"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentStep2View">

    <UserControl.Resources>
        <converters:CropTypeToColorConverter x:Key="CropTypeToColorConverter"/>
        <converters:IndexToOrdinalConverter x:Key="IndexToOrdinalConverter"/>
        <dataTemplates:CropGroupedItemDataTemplate x:Key="CropGroupedItemDataTemplate"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ComboBox.crop-selector /template/ Border#Background">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="ComboBox.crop-selector ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ComboBox.crop-selector ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EBF2FA"/>
        </Style>
    </UserControl.Styles>

    <Design.DataContext>
        <field:FieldComponentViewModelDesign />
    </Design.DataContext>

    <StackPanel>

        <!-- Step Header with Vertical Layout -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <!-- Step Badge -->
            <Border Classes="step-badge" VerticalAlignment="Top">
                <TextBlock Text="{Binding [Label_StepTwo].Value, Source={StaticResource Loc}}" Classes="step-badge-text" />
            </Border>

            <StackPanel VerticalAlignment="Center">
                <!-- Step Description -->
                <TextBlock Text="{Binding [Label_EnterFieldHistory].Value, Source={StaticResource Loc}}"
                           Classes="step-number-description" />
            </StackPanel>
        </StackPanel>

        <!-- Step header separator -->
        <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Command="{Binding AddCropCommand}" Classes="add-group" Content="{Binding [Button_AddCropToField].Value, Source={StaticResource Loc}}" />
        </StackPanel>

        <!-- Crop Table — only visible when crops exist -->
        <StackPanel IsVisible="{Binding SelectedFieldSystemComponentDto.CropDtos.Count}">

            <!-- Table Header -->
            <Border Background="#F3F4F6" Padding="8,6"
                    BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    BorderThickness="1,1,1,1" CornerRadius="6,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Year" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Main Crop" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Cover Crop" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource GcdsTextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Table Rows -->
            <Border BorderBrush="{StaticResource GcdsBorderLightBrush}"
                    BorderThickness="1,0,1,1" CornerRadius="0,0,6,6"
                    ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding Path=SelectedFieldSystemComponentDto.CropDtos}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Border Padding="8,6"
                                        BorderBrush="{StaticResource GcdsBorderLightBrush}"
                                        BorderThickness="0,0,0,1"
                                        Background="{Binding CropType, Converter={StaticResource CropTypeToColorConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Year -->
                                        <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Year}"/>

                                        <!-- Main Crop -->
                                        <ComboBox Grid.Column="1" Classes="crop-selector"
                                                  ItemsSource="{Binding GroupedCropItems}"
                                                  SelectedItem="{Binding SelectedCropTypeItem}"
                                                  ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                  HorizontalAlignment="Stretch"
                                                  Margin="8,0,0,0"
                                                  MaxDropDownHeight="320"/>

                                        <!-- Cover Crop -->
                                        <DockPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <Button DockPanel.Dock="Left" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,6,0"
                                                    Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).ToggleCoverCropCommand}"
                                                    CommandParameter="{Binding}">
                                                <CheckBox IsChecked="{Binding HasCoverCrop, Mode=OneWay}"
                                                          IsHitTestVisible="False" MinWidth="0" Padding="0"/>
                                            </Button>
                                            <TextBlock DockPanel.Dock="Left" Text="None" FontSize="11" Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                       IsVisible="{Binding !HasCoverCrop}" VerticalAlignment="Center" FontStyle="Italic"/>
                                            <ComboBox Classes="crop-selector"
                                                      IsVisible="{Binding HasCoverCrop}"
                                                      ItemsSource="{Binding CoverCropDto.GroupedCropItems}"
                                                      SelectedItem="{Binding CoverCropDto.SelectedCropTypeItem}"
                                                      ItemTemplate="{StaticResource CropGroupedItemDataTemplate}"
                                                      HorizontalAlignment="Stretch"
                                                      MaxDropDownHeight="320"/>
                                        </DockPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1"
                                                    CornerRadius="4" Padding="4,2" MinWidth="0" MinHeight="0" Width="24" Height="24"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).RemoveSpecificCropCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="🗑" FontSize="11"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
