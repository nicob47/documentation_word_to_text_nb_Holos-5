<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentStep2View">

    <Design.DataContext>
        <field:FieldComponentViewModelDesign />
    </Design.DataContext>

    <StackPanel>

        <!-- Step Header with Vertical Layout -->
        <StackPanel Margin="0,0,0,20">
            <!-- Step Badge -->
            <Border Classes="step-badge" HorizontalAlignment="Left">
                <TextBlock Text="Step 2" Classes="step-badge-text" />
            </Border>

            <!-- Step Description below badge -->
            <TextBlock Text="Enter field history"
                       Classes="step-number-description"
                       Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Command="{Binding AddCropCommand}" Classes="add-group" Content="Add Crop" />
        </StackPanel>

        <!-- Timeline Container -->
        <Border Classes="timeline-container">
            <StackPanel>
                <!-- Timeline Header -->
                <TextBlock Text="Field History Timeline" Classes="timeline-header" />

                <!-- Timeline Scrollable Area -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden"
                              MaxHeight="250"
                              MinHeight="150">
                    <ItemsControl ItemsSource="{Binding Path=SelectedFieldSystemComponentDto.CropDtos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Timeline Card -->
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="4"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).SetSelectedCropCommand}"
                                        CommandParameter="{Binding}">

                                    <Border Classes="timeline-card">
                                        <StackPanel Spacing="8" Margin="8">
                                            <!-- Top row with Year Badge and Delete Button in same DockPanel for perfect alignment -->
                                            <DockPanel LastChildFill="False">
                                                <!-- Year Badge -->
                                                <Border Classes="year-badge" 
                                                        DockPanel.Dock="Left"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Path=Year}" 
                                                               Classes="year-badge-text"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                                
                                                <!-- Delete Button -->
                                                <Button  Classes="delete-button"
                                                         DockPanel.Dock="Right"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).RemoveSpecificCropCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Name="DeleteTextBlock" 
                                                               Classes="delete-text"
                                                               Text="Delete"/>
                                                </Button>
                                            </DockPanel>
                                            
                                            <!-- Crop Type Section -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Select crop"
                                                           FontSize="11"
                                                           Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Left" />

                                                <ComboBox ItemsSource="{Binding Path=ValidCropTypes}"
                                                          SelectedItem="{Binding Path=CropType}"
                                                          MinWidth="140"
                                                          HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>


                <!-- Timeline Navigation Hint -->
                <TextBlock Text="Tip: Scroll horizontally to view all crops, selected crop will be highlighted"
                           Classes="timeline-hint" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>