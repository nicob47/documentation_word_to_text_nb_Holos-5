<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cropTabs="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.CropTabs"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.SelectedCropTabView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Step Header with inline editing info -->
        <Grid Grid.Row="0" Margin="10,8,10,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Step badge + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <Border Classes="step-badge" VerticalAlignment="Top">
                    <TextBlock Text="{Binding [Label_StepFour].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Label_DefineManagementPractices].Value, Source={StaticResource Loc}}"
                               Classes="step-number-description"/>
                </StackPanel>
            </StackPanel>

            <!-- Right: Currently editing info + toggles -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}">
                <!-- Crop info -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold">
                        <Run Text="{Binding SelectedCropDto.CropType, Mode=OneWay}"/>
                        <Run Text="("/>
                        <Run Text="{Binding SelectedCropDto.Year, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </StackPanel>

                <!-- Separator -->
                <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1,0,0,0" Height="30"/>

                <!-- Cover crop toggle -->
                <ToggleSwitch IsVisible="{Binding SelectedCropDto.HasCoverCrop, FallbackValue=False}"
                              IsChecked="{Binding IsEditingCoverCrop}"
                              OnContent="{Binding SelectedCropDto.CoverCropDto.CropType, StringFormat='Cover Crop ({0})'}"
                              OffContent="{Binding SelectedCropDto.CropType, StringFormat='Main Crop ({0})'}"
                              VerticalAlignment="Center" Padding="0" Margin="0"/>

                <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="1,0,0,0" Height="30"
                        IsVisible="{Binding SelectedCropDto.HasCoverCrop, FallbackValue=False}"/>
            </StackPanel>
        </Grid>

        <!-- Step header separator -->
        <Border Grid.Row="1" BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

        <!-- Checklist Editor - shown when NOT editing cover crop -->
        <cropTabs:CropChecklistEditorView Grid.Row="2"
            IsVisible="{Binding DataContext.IsEditingCoverCrop, Converter={x:Static BoolConverters.Not}, RelativeSource={RelativeSource AncestorType=UserControl}}"
            DataContext="{Binding SelectedCropDto}"
            IsFertilizerActive="{Binding DataContext.IsFertilizerActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsManureActive="{Binding DataContext.IsManureActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsGrazingActive="{Binding DataContext.IsGrazingActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsSoilActive="{Binding DataContext.IsSoilActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsResidueActive="{Binding DataContext.IsResidueActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEconomicsActive="{Binding DataContext.IsEconomicsActive, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <!-- Checklist Editor - shown when editing cover crop -->
        <cropTabs:CropChecklistEditorView Grid.Row="2"
            IsVisible="{Binding DataContext.IsEditingCoverCrop, RelativeSource={RelativeSource AncestorType=UserControl}}"
            DataContext="{Binding SelectedCropDto.CoverCropDto}"
            IsFertilizerActive="{Binding DataContext.IsFertilizerActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsManureActive="{Binding DataContext.IsManureActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsGrazingActive="{Binding DataContext.IsGrazingActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsSoilActive="{Binding DataContext.IsSoilActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsResidueActive="{Binding DataContext.IsResidueActive, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEconomicsActive="{Binding DataContext.IsEconomicsActive, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

    </Grid>
</UserControl>
