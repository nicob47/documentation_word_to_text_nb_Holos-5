<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:fieldViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
             xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
             xmlns:avalonia="clr-namespace:H.Avalonia"
             xmlns:converters="clr-namespace:H.Avalonia.Converters"
             xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentView">

	<Design.DataContext>
		<field:FieldComponentViewModelDesign/>
	</Design.DataContext>

	<UserControl.Resources>
		<converters:BoolToSelectionBorderThicknessConverter x:Key="BoolToSelectionBorderThicknessConverter"/>
		<converters:BoolToSelectionBorderBrushConverter x:Key="BoolToSelectionBorderBrushConverter"/>
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<!-- Title + Advanced Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<TextBox Classes="view-title" Text="{Binding Path=SelectedFieldSystemComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

		<!-- Step 1 -->
		<Border Grid.Row="0" Classes="step-container" Margin="{StaticResource DefaultUserControlMargin}">
			<fieldViews:FieldComponentStep1View/>
		</Border>

		<!-- Step 2 -->
		<Border Grid.Row="1" Classes="step-container" Margin="{StaticResource DefaultUserControlMargin}">
			<fieldViews:FieldComponentStep2View/>
		</Border>

		<!-- Field Preview Strip -->
		<Border Grid.Row="2" Classes="step-container" Margin="{StaticResource DefaultUserControlMargin}"
		        IsVisible="{Binding ShouldShowFieldPreview}">
			<StackPanel>
				<!-- Step Header -->
				<StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
					<Border Classes="step-badge" VerticalAlignment="Top">
						<TextBlock Text="{Binding [Label_StepThree].Value, Source={StaticResource Loc}}" Classes="step-badge-text"/>
					</Border>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Preview Field Assignments"
						           Classes="step-number-description"/>
						<TextBlock Text="Review how crops are assigned across years"
						           Foreground="{StaticResource GcdsTextSecondaryBrush}"
						           FontSize="12"
						           Margin="0,2,0,0"/>
					</StackPanel>
				</StackPanel>

				<!-- Step header separator -->
				<Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>

				<!-- Preview Grid -->
				<ScrollViewer HorizontalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding FieldPreviewAssignments}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="8"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Background="Transparent"
								        BorderThickness="0"
								        Padding="0"
								        Cursor="Hand"
								        Command="{Binding $parent[UserControl].((field:FieldComponentViewModel)DataContext).SetSelectedCropFromCellCommand}"
								        CommandParameter="{Binding}">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="Transparent"/>
										</Style>
										<Style Selector="Button:pressed">
											<Setter Property="Background" Value="Transparent"/>
										</Style>
									</Button.Styles>
									<Border Background="{Binding CropBackground}"
									        Padding="8,8"
									        Width="120"
									        Height="80"
									        CornerRadius="4"
									        BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToSelectionBorderBrushConverter}}"
									        BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToSelectionBorderThicknessConverter}}">
										<Border.Styles>
											<Style Selector="Border:pointerover">
												<Setter Property="Opacity" Value="0.85"/>
											</Style>
										</Border.Styles>
										<StackPanel Spacing="2" VerticalAlignment="Center">
											<!-- Year label -->
											<TextBlock Text="{Binding Year}"
											           FontSize="12"
											           FontWeight="SemiBold"
											           Foreground="{StaticResource GcdsTextSecondaryBrush}"
											           TextAlignment="Center"/>
											<!-- Crop name -->
											<TextBlock Text="{Binding CropDisplay}"
											           TextAlignment="Center"
											           TextWrapping="Wrap"
											           TextTrimming="CharacterEllipsis"
											           MaxLines="2"
											           FontWeight="Medium"
											           Foreground="{DynamicResource TextControlForeground}"
											           ToolTip.Tip="{Binding CropDisplay}"/>
											<!-- Cover crop indicator -->
											<TextBlock Text="{Binding CoverCropDisplay}"
											           IsVisible="{Binding HasCoverCrop}"
											           TextAlignment="Center"
											           FontSize="10"
											           FontStyle="Italic"
											           Foreground="#2E7D32"
											           TextTrimming="CharacterEllipsis"
											           MaxLines="1"
											           ToolTip.Tip="{Binding CoverCropDisplay}"/>
										</StackPanel>
									</Border>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

				<!-- Hint text -->
				<TextBlock Text="Click a crop card above to edit its properties."
				           FontSize="12" FontStyle="Italic"
				           Foreground="{StaticResource GcdsTextSecondaryBrush}"
				           Margin="0,8,0,0"/>
			</StackPanel>
		</Border>

		<!-- Step 4 — only visible when a crop is selected -->
		<Border Grid.Row="3" Classes="step-container" Margin="{StaticResource DefaultUserControlMargin}"
		        IsVisible="{Binding SelectedCropDto, Converter={x:Static ObjectConverters.IsNotNull}}">
			<fieldViews:SelectedCropTabView x:Name="SelectedCropTabViewControl"/>
		</Border>

			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>
