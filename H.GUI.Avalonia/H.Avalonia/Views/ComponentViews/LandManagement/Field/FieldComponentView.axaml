<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:fieldViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
             xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
             xmlns:avalonia="clr-namespace:H.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentView">

	<Design.DataContext>
		<field:FieldComponentViewModelDesign/>
	</Design.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<!-- Title -->
			<RowDefinition Height="Auto"/>
			<!-- Advanced Options Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<!-- Title -->
			<TextBox Classes="view-title" Text="{Binding Path=SelectedFieldSystemComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Advanced Options Toggle Section -->
		<shared:AdvancedOptionsToggleView Grid.Row="1"
		                                  Margin="{StaticResource DefaultUserControlMargin}"
		                                  Title="{Binding [Label_ShowAdvancedOptions].Value, Source={StaticResource Loc}}"
		                                  Description="{Binding [Label_ShowAdvancedOptionsFieldDesc].Value, Source={StaticResource Loc}}"
		                                  IsChecked="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"/>

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<Grid>
			<Grid.RowDefinitions>
				<!-- Step 1 row -->
                <RowDefinition Height="Auto"/>

                <!-- Step 1 GridSplitter row -->
				<RowDefinition Height="Auto"/>

                <!-- Step 2 row - Auto height to accommodate timeline -->
				<RowDefinition Height="Auto"/>

                <!-- Step 2 GridSplitter row -->
				<RowDefinition Height="Auto"/>

                <!-- Step 3 row - Auto height to ensure visibility -->
				<RowDefinition Height="Auto"/>
				
			</Grid.RowDefinitions>

		<!-- Begin step 1 -->
		<Border Grid.Row="0"
		        Classes="step-container"
		        Margin="{StaticResource DefaultUserControlMargin}">
			<fieldViews:FieldComponentStep1View/>
		</Border>
		<!-- End step 1 -->

		<!-- Begin step 2 -->
		<Border Grid.Row="2"
		        Classes="step-container"
		        Margin="{StaticResource DefaultUserControlMargin}">
			<fieldViews:FieldComponentStep2View/>
		</Border>
		<!-- End step 2 -->

		<!-- Begin step 3 -->
		<Border Grid.Row="4"
		        Classes="step-container"
		        Margin="{StaticResource DefaultUserControlMargin}">
			<fieldViews:SelectedCropTabView x:Name="SelectedCropTabViewControl"/>
		</Border>
		<!-- End step 3 -->

			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>
