<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement"
             xmlns:shelterbeltVm="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Shelterbelt"
             xmlns:shelterbeltViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Shelterbelt"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.ShelterbeltComponentView">

    <UserControl.DataTemplates>
        <!-- Implicit DataTemplate mapping: each step VM type → its view -->
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep1WelcomeViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep1WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep2LocationViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep2LocationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep3RowCountViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep3RowCountView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep4RowDetailsViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep4RowDetailsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep5SpeciesViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep5SpeciesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type shelterbeltVm:ShelterbeltWizardStep6ReviewViewModel}">
            <shelterbeltViews:ShelterbeltWizardStep6ReviewView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Component title — always visible -->
            <RowDefinition Height="Auto"/>
            <!-- Wizard progress header — wizard mode only -->
            <RowDefinition Height="Auto"/>
            <!-- Current step content — wizard mode only -->
            <RowDefinition Height="*"/>
            <!-- Navigation buttons — wizard mode only -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 0 — Component title (always visible in both modes)
             ═══════════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="{StaticResource DefaultUserControlMargin}">
            <TextBlock Text="Shelterbelt"
                       Classes="step-number-description"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
            <Border Classes="title-underline"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════════
             Rows 1–3 — Wizard chrome (hidden in summary mode)
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- Row 1: global step pill + step title -->
        <Border Grid.Row="1"
                IsVisible="{Binding !IsSummaryMode}"
                Classes="step-container"
                Margin="{StaticResource DefaultUserControlMargin}">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Classes="step-badge" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressLabel}"
                               Classes="step-badge-text"/>
                </Border>
                <TextBlock Text="{Binding CurrentStep.StepTitle}"
                           Classes="step-number-description"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 2: current step content resolved via DataTemplates above -->
        <Border Grid.Row="2"
                IsVisible="{Binding !IsSummaryMode}"
                Classes="step-container"
                Margin="{StaticResource DefaultUserControlMargin}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding CurrentStep}"/>
            </ScrollViewer>
        </Border>

        <!-- Row 3: Back / Next / Finish navigation buttons -->
        <Border Grid.Row="3"
                IsVisible="{Binding !IsSummaryMode}"
                Margin="{StaticResource DefaultUserControlMargin}"
                Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding GoBackCommand}"
                        IsVisible="{Binding !IsFirstStep}"
                        Margin="0,0,8,0"
                        Padding="16,8"/>

                <Button Grid.Column="2"
                        Content="{Binding NextButtonLabel}"
                        Command="{Binding GoNextCommand}"
                        Padding="16,8"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Rows 1–3 — Summary / neutral state (shown after wizard Finish)
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.RowSpan="3"
              IsVisible="{Binding IsSummaryMode}">
            <Grid.RowDefinitions>
                <!-- "Done" badge strip — mirrors the wizard progress header -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable data summary -->
                <RowDefinition Height="*"/>
                <!-- Edit button footer — mirrors the wizard nav buttons -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Summary header: non-interactive status indicator + shelterbelt name -->
            <Border Grid.Row="0"
                    Classes="step-container"
                    Margin="{StaticResource DefaultUserControlMargin}">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <!-- Checkmark label — NOT a button, just a status indicator -->
                    <TextBlock Text="&#x2713; Saved"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{StaticResource GcdsTextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="|"
                               Foreground="{StaticResource GcdsBorderDefaultBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Summary.ShelterbeltName}"
                               Classes="step-number-description"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Summary content: location overview + per-row cards -->
            <Border Grid.Row="1"
                    Classes="step-container"
                    Margin="{StaticResource DefaultUserControlMargin}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" Margin="0,4,0,4">

                        <!-- Location + row-count overview line -->
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Hardiness zone:"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Summary.HardinessZoneDisplay}"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Eco-district:"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Summary.EcoDistrictId}"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Rows:"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Summary.RowCount}"
                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Subtle divider -->
                        <Border BorderBrush="{StaticResource GcdsBorderSubtleBrush}"
                                BorderThickness="0,0,0,1"/>

                        <!-- Per-row summary cards -->
                        <ItemsControl ItemsSource="{Binding Summary.Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="input-card"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding RowHeader}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Margin="0,0,0,4"
                                                       Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Length:"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding RowLength, StringFormat=N1}"
                                                           Foreground="{StaticResource GcdsTextPrimaryBrush}"/>
                                                <TextBlock Text="m"
                                                           Foreground="{StaticResource GcdsTextSecondaryBrush}"/>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding TreeGroups}"
                                                          Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                                                                   Margin="0,2,0,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Summary footer: Edit wizard button -->
            <Border Grid.Row="2"
                    Margin="{StaticResource DefaultUserControlMargin}"
                    Padding="4">
                <Button Content="Edit wizard"
                        Command="{Binding EditCommand}"
                        Padding="16,8"/>
            </Border>

        </Grid>

    </Grid>
</UserControl>
