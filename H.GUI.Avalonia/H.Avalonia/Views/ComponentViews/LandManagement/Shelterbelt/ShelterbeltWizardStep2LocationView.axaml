<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Shelterbelt.ShelterbeltWizardStep2LocationView">

    <StackPanel Spacing="16" Margin="0,8,0,8">

        <TextBlock Text="{Binding [Text_ShelterbeltWizardStep2Instruction].Value, Source={StaticResource Loc}}"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   FontSize="14"
                   TextWrapping="Wrap"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="160" Width="Auto"/>
                <ColumnDefinition MinWidth="200" Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Hardiness Zone -->
            <Label Grid.Row="0" Grid.Column="0"
                   Content="{Binding [Label_HardinessZoneField].Value, Source={StaticResource Loc}}"
                   VerticalAlignment="Center"
                   Classes="input-label"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      AutomationProperties.Name="{Binding [Label_HardinessZone].Value, Source={StaticResource Loc}}"
                      ItemsSource="{Binding HardinessZones}"
                      SelectedItem="{Binding SelectedHardinessZone}"
                      MinWidth="200"/>

            <!-- Eco-district ID -->
            <Label Grid.Row="1" Grid.Column="0"
                   Content="{Binding [Label_EcodistrictId].Value, Source={StaticResource Loc}}"
                   VerticalAlignment="Center"
                   Classes="input-label"
                   Margin="0,8,0,0"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           AutomationProperties.Name="{Binding [Label_Ecodistrict].Value, Source={StaticResource Loc}}"
                           Value="{Binding EcoDistrictId}"
                           Minimum="0"
                           FormatString="0"
                           ParsingNumberStyle="Integer"
                           Margin="0,8,0,0"
                           MinWidth="120"/>
        </Grid>

        <TextBlock Text="{Binding [Text_ShelterbeltWizardStep2EcodistrictHint].Value, Source={StaticResource Loc}}"
                   FontSize="12"
                   FontStyle="Italic"
                   Foreground="{StaticResource GcdsTextSecondaryBrush}"
                   TextWrapping="Wrap"/>

    </StackPanel>
</UserControl>
