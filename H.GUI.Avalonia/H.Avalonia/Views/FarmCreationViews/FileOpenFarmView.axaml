<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:H.Localization.Resources.Strings;assembly=H.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:viewSections="clr-namespace:H.Avalonia"
			 xmlns:farmCreationViews="clr-namespace:H.Avalonia.Views.FarmCreationViews"
			 x:Class="H.Avalonia.Views.FarmCreationViews.FileOpenFarmView">
	
	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
		<TextBlock Text="{Binding [Label_OpenAnExistingFarm].Value, Source={StaticResource Loc}}"
				   HorizontalAlignment="Center" Margin="0,0,0,30" FontWeight="Bold" FontSize="{StaticResource GcdsFontSizeH5}" Foreground="{StaticResource GcdsTextSecondaryBrush}" />
		
		<farmCreationViews:FarmDataGridSharedView/>
		
		<StackPanel Orientation="Vertical" Width="160">
			<Button Content="{Binding [Button_Open].Value, Source={StaticResource Loc}}" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" Command="{Binding NavigateToNextPage}" Margin="0 120 0 0" />
		</StackPanel>
	</StackPanel>
</UserControl>
