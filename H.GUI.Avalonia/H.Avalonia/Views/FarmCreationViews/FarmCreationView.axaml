<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
             xmlns:farmCreationViews="clr-namespace:H.Avalonia.ViewModels.FarmCreationViews"
             xmlns:farmCreationViews1="clr-namespace:H.Avalonia.Views.FarmCreationViews"
             x:Class="H.Avalonia.Views.FarmCreationViews.FarmCreationView">

    <Design.DataContext>
        <farmCreationViews:FarmCreationViewModelDesign />
    </Design.DataContext>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <farmCreationViews1:FarmCreationSharedView />

        <Border BorderBrush="{StaticResource GcdsBorderLightBrush}" BorderThickness="0,0,0,1" Margin="0,20" Width="450" />
        <Button Classes="back-button" Content="{x:Static properties:Resources.ButtonGoBack}" Margin="0 10 0 0"
                HorizontalAlignment="Center" Command="{Binding NavigateToPreviousPage}" />
    </StackPanel>
</UserControl>